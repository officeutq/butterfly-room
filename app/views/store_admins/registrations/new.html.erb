<div style="max-width: 720px;">
  <h1 class="h4 mb-3">store_admin 新規登録（招待専用）</h1>

  <div class="alert alert-secondary" role="alert">
    招待の承認には store_admin アカウントが必要です。アカウントを作成してください。
  </div>

  <%= form_with model: @form,
        url: store_admin_sign_up_path(token: params[:token]),
        scope: :store_admin_registration do |f| %>

    <% if @form.errors.any? %>
      <div class="alert alert-danger" role="alert">
        <ul class="mb-0">
          <% @form.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, class: "form-control", autocomplete: "email" %>
    </div>

    <div class="mb-3">
      <%= f.label :password, class: "form-label" %>
      <%= f.password_field :password, class: "form-control", autocomplete: "new-password" %>
    </div>

    <div class="mb-3">
      <%= f.label :password_confirmation, class: "form-label" %>
      <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
    </div>

    <p class="small text-secondary mb-3">
      登録することで、
      <%= link_to "利用規約", terms_path, target: "_blank", rel: "noopener" %>
      および
      <%= link_to "プライバシーポリシー", privacy_policy_path, target: "_blank", rel: "noopener" %>
      に同意したものとみなします。
    </p>

    <div class="d-flex gap-2">
      <%= f.submit "登録して続行", class: "btn btn-primary" %>
      <%= link_to "戻る（招待ページ）",
            store_admin_invitation_path(params[:token]),
            class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
</div>
