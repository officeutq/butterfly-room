<% content_for :head do %>
  <%= render "shared/filepond_head" %>
<% end %>
<% content_for :title, "プロフィール編集" %>

<div class="card mb-3">
  <div class="card-body">
    <div class="form-label mb-1">メールアドレス</div>
    <div class="mb-3"><%= @user.email %></div>

    <%= link_to "メールアドレスを変更",
          edit_email_change_path,
          class: "btn btn-outline-secondary btn-sm" %>
  </div>
</div>

<%= form_with model: @user, url: profile_path do |f| %>
  <div class="mb-3">
    <%= f.label :display_name, "表示名", class: "form-label" %>
    <%= f.text_field :display_name, class: "form-control" %>
    <div class="form-text">未入力の場合は email が表示されます（将来変更の可能性あり）</div>
  </div>

  <div class="mb-3">
    <%= f.label :bio, "自己紹介（bio）", class: "form-label" %>
    <%= f.text_area :bio, class: "form-control", rows: 6 %>
    <div class="form-text">最大500文字</div>
  </div>

  <div
    class="mb-3 image-upload-field"
    data-controller="image-upload"
    data-image-upload-width-value="1024"
    data-image-upload-height-value="1024"
    <% if @user.avatar.attached? && @user.avatar.blob&.persisted? %>
      data-image-upload-initial-url-value="<%= url_for(@user.avatar) %>"
    <% end %>>
    <%= f.label :avatar, "プロフィール画像", class: "form-label" %>

    <%= f.hidden_field :remove_avatar,
          value: "0",
          data: { "image-upload-target": "removeFlag" } %>

    <%= f.file_field :avatar,
          accept: ".jpg,.jpeg,.png,.webp,.heic,.heif",
          data: { "image-upload-target": "input" } %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit "更新する", class: "btn btn-primary" %>
    <%= link_to "戻る", dashboard_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
