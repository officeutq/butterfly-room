<% if user_signed_in? %>
  <%# --- Search (Input group / GET) --- %>
  <div class="mb-3">
    <%= form_with url: root_path, method: :get, scope: nil do |f| %>
      <%= f.hidden_field :mode, value: @mode %>

      <div class="input-group">
        <div class="btn-group">
          <button
            class="btn btn-outline-secondary dropdown-toggle"
            type="button"
            data-bs-toggle="dropdown"
            aria-expanded="false">
            <%= @mode == "stores" ? "店舗" : "ブース" %>
          </button>

          <ul class="dropdown-menu">
            <li>
              <%= link_to "ブース",
                    root_path(mode: "booths", q: @q.presence),
                    class: "dropdown-item" %>
            </li>
            <li>
              <%= link_to "店舗",
                    root_path(mode: "stores", q: @q.presence),
                    class: "dropdown-item" %>
            </li>
          </ul>
        </div>

        <%= f.text_field :q,
              value: @q,
              class: "form-control",
              placeholder: "ブース名 / ストア名で検索（部分一致）",
              autocomplete: "off" %>

        <button class="btn btn-primary" type="submit" aria-label="検索">
          <i class="bi bi-search"></i>
        </button>
      </div>
    <% end %>
  </div>

  <%# --- Results (cards) --- %>
  <% if @mode == "stores" %>
    <% if @stores.present? %>
      <div class="row row-cols-1 row-cols-md-3 g-3">
        <% @stores.each do |store| %>
          <% favorited = @favorite_store_ids.include?(store.id) %>

          <div class="col">
            <div class="card h-100">
              <div class="card-body">
                <div class="fw-semibold">
                  <%= link_to store.name, store_path(store), class: "text-decoration-none text-reset" %>
                </div>
              </div>

              <div class="card-footer bg-white border-0 pt-0">
                <%= render "favorites/stores/button_home", store: store, favorited: favorited %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary" role="alert">
        表示できる店舗がありません。
      </div>
    <% end %>
  <% else %>
    <% if @booths.present? %>
      <div class="row row-cols-1 row-cols-md-3 g-3">
        <% @booths.each do |booth| %>
          <div class="col">
            <%= render "booths/card",
                  booth: booth,
                  booth_favorited: @favorite_booth_ids.include?(booth.id),
                  store_favorited: @favorite_store_ids.include?(booth.store_id) %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary" role="alert">
        表示できるブースがありません。
      </div>
    <% end %>
  <% end %>
<% else %>
  <div style="max-width: 720px;">
    <h1 class="mb-3">ようこそ</h1>
    <p class="text-muted">視聴するにはログイン、または新規アカウント作成を行ってください。</p>

    <div class="d-flex gap-2 mt-3">
      <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary" %>
      <%= link_to "新規アカウント作成", sign_up_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
<% end %>
