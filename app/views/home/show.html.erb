<% if user_signed_in? %>
  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h1 class="h4 mb-0">ブース一覧</h1>
      <div class="text-muted small">
        ログイン中: <%= current_user.email %>（role: <%= current_user.role %>）
      </div>
    </div>

    <% if @booths.present? %>
      <div class="row row-cols-1 row-cols-md-3 g-3">
        <% @booths.each do |booth| %>
          <% primary_cast = booth.booth_casts.max_by { |bc| [bc.created_at, bc.id] }&.cast_user %>
          <% favorited = @favorite_booth_ids.include?(booth.id) %>

          <div class="col">
            <div class="card h-100">
              <%= link_to booth_path(booth), class: "text-decoration-none text-reset" do %>
                <% if booth.thumbnail_image.attached? %>
                  <%= image_tag booth.thumbnail_image,
                        class: "card-img-top",
                        style: "aspect-ratio: 16 / 9; object-fit: cover;" %>
                <% else %>
                  <div class="bg-light d-flex align-items-center justify-content-center"
                       style="aspect-ratio: 16 / 9;">
                    <span class="text-muted small">no thumbnail</span>
                  </div>
                <% end %>
              <% end %>

              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start gap-2">
                  <div class="fw-semibold">
                    <%= link_to booth.name, booth_path(booth), class: "text-decoration-none text-reset" %>
                  </div>
                  <div><%= booth_status_badge(booth) %></div>
                </div>

                <div class="mt-2 text-muted small">
                  <% if primary_cast.present? %>
                    cast: <%= display_name_or_email(primary_cast) %>
                  <% else %>
                    cast: <span class="text-muted">（未設定）</span>
                  <% end %>
                </div>

                <div class="text-muted small">
                  store: <%= booth.store&.name %>
                </div>
              </div>

              <div class="card-footer bg-white border-0 pt-0">
                <div id="booth_<%= booth.id %>_favorite_button">
                  <%= render "favorites/booths/button", booth: booth, favorited: favorited %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary" role="alert">
        表示できるブースがありません。
      </div>
    <% end %>

    <hr class="my-4">

    <h2 class="h5 mb-3">店舗一覧</h2>

    <% if @stores.present? %>
      <div class="list-group mb-4">
        <% @stores.each do |store| %>
          <% favorited = @favorite_store_ids.include?(store.id) %>

          <div class="list-group-item">
            <div class="d-flex justify-content-between align-items-center gap-3">
              <div class="flex-grow-1">
                <%= link_to store.name, store_path(store), class: "text-decoration-none" %>
              </div>

              <div id="store_<%= store.id %>_favorite_button">
                <%= render "favorites/stores/button", store: store, favorited: favorited %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="alert alert-secondary" role="alert">
        表示できる店舗がありません。
      </div>
    <% end %>

    <hr class="my-4">

    <%# --- Dev / role entry links (暫定) --- %>
    <h2 class="h6">導線（暫定）</h2>
    <ul class="mb-3">
      <li><%= link_to "お気に入り（ブース）", favorites_booths_path %></li>
      <li><%= link_to "お気に入り（店舗）", favorites_stores_path %></li>
      <li><%= link_to "Cast booths", cast_booths_path %></li>
      <li><%= link_to "Store Admin Dashboard", admin_root_path %></li>
      <li><%= link_to "System Admin Dashboard", system_admin_root_path %></li>
      <li><%= link_to "店舗として登録（ref=TEST）", stores_new_registration_path(ref: "TEST") %></li>
    </ul>

    <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-outline-secondary" %>
  </div>
<% else %>
  <div class="container mt-4" style="max-width: 720px;">
    <h1 class="mb-3">ようこそ</h1>
    <p class="text-muted">視聴するにはログイン、または新規アカウント作成を行ってください。</p>

    <div class="d-flex gap-2 mt-3">
      <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary" %>
      <%= link_to "新規アカウント作成", sign_up_path, class: "btn btn-outline-primary" %>
    </div>
  </div>
<% end %>
