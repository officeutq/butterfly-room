<div style="max-width: 960px;">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div>
      <h1 class="mb-1">ダッシュボード</h1>
      <p class="text-muted mb-0">ロール別リンク</p>
    </div>
  </div>

  <hr class="my-4">

  <% store = layout_current_store %>
  <% booth = layout_current_booth %>

  <%#=== system_admin ===%>
  <% if current_user.system_admin? %>
    <h2 class="h5 mb-3">system_admin</h2>

    <ul class="list-group mb-4">
      <li class="list-group-item">
        <%= link_to "ユーザー管理", system_admin_users_path, class: "text-decoration-none" %>
      </li>
      <li class="list-group-item">
        <%= link_to "紹介コード管理", system_admin_referral_codes_path, class: "text-decoration-none" %>
      </li>

      <li class="list-group-item">
        <%= link_to "マニュアル精算（テスト）", "/system_admin/settlements/manual/new", class: "text-decoration-none" %>
      </li>

      <li class="list-group-item">
        <%= link_to "振込CSV（住信SBI）", system_admin_settlement_exports_path, class: "text-decoration-none" %>
      </li>

      <li class="list-group-item">
        <%= link_to "精算一覧", system_admin_settlements_path, class: "text-decoration-none" %>
      </li>
    </ul>

    <ul class="list-group mb-4">
      <li class="list-group-item">
        <%= link_to "店舗一覧", admin_stores_path, class: "text-decoration-none" %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "店舗設定", edit_admin_store_path(store), class: "text-decoration-none" %>
        <% else %>
          <%= link_to "店舗設定",
                admin_stores_path(return_to_key: "store_edit"),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "ブース一覧", admin_booths_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "ブース一覧",
                admin_stores_path(return_to: admin_booths_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if booth.present? %>
          <%= link_to "ブースを編集", edit_cast_booth_path(booth), class: "text-decoration-none" %>
        <% else %>
          <%= link_to "ブースを編集",
                cast_booths_path(return_to_key: "booth_edit"),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "キャスト管理", admin_casts_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "キャスト管理",
                admin_stores_path(return_to: admin_casts_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "ブースにキャストを紐づける", admin_booth_casts_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "ブースにキャストを紐づける",
                admin_stores_path(return_to: admin_booth_casts_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "キャスト別数値一覧（直近30日）", admin_cast_metrics_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "キャスト別数値一覧（直近30日）",
                admin_stores_path(return_to: admin_cast_metrics_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "ドリンクメニュー", admin_drink_items_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "ドリンクメニュー",
                admin_stores_path(return_to: admin_drink_items_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "店舗BAN", admin_store_bans_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "店舗BAN",
                admin_stores_path(return_to: admin_store_bans_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to edit_admin_payout_account_path, class: "text-decoration-none" do %>
            精算・振込設定
            <% if store.payout_account_unconfigured? %>
              <span class="badge text-bg-warning ms-2">未設定</span>
            <% end %>
          <% end %>
        <% else %>
          <%= link_to "精算・振込設定",
                admin_stores_path(return_to_key: "payout_account_edit"),
                class: "text-decoration-none" %>
        <% end %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "精算（予定・履歴）", admin_settlements_path, class: "text-decoration-none" %>
        <% else %>
          <%= link_to "精算（予定・履歴）",
                admin_stores_path(return_to: admin_settlements_path),
                class: "text-decoration-none" %>
        <% end %>
      </li>
    </ul>

    <ul class="list-group mb-4">
      <li class="list-group-item">
        <%= link_to "プロフィール編集", edit_profile_path, class: "text-decoration-none" %>
      </li>
    </ul>

  <%#=== store_admin ===%>
  <% elsif current_user.store_admin? %>
    <h2 class="h5 mb-3">store_admin</h2>

    <ul class="list-group mb-4">
      <li class="list-group-item">
        <%= link_to "店舗一覧", admin_stores_path, class: "text-decoration-none" %>
      </li>

      <li class="list-group-item">
        <% if store.present? %>
          <%= link_to "店舗設定", edit_admin_store_path(store), class: "text-decoration-none" %>
        <% else %>
          <%= link_to "店舗設定",
