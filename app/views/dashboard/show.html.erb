<% content_for :title, "ダッシュボード" %>
<div class="container px-0">
  <% store = layout_current_store %>
  <% booth = layout_current_booth %>

  <div class="row g-3">
    <% if current_user.at_least?(:customer) %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to edit_profile_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-customer" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">プロフィール編集</h5>
              <p class="card-text mb-0">プロフィールやアイコンを編集します</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if current_user.at_least?(:customer) %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to phone_verification_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-customer" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">
                電話番号認証
                <% if current_user.phone_verified? %>
                  <span class="badge text-bg-success ms-2">認証済み</span>
                <% else %>
                  <span class="badge text-bg-warning ms-2">未認証</span>
                <% end %>
              </h5>
              <p class="card-text mb-0">
                <% if current_user.phone_verified? %>
                  認証済み電話番号の確認・変更を行います
                <% else %>
                  電話番号を登録して認証します。電話番号でもログインできるようになります。
                <% end %>
              </p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if current_user.cast? && @cast_booths_count >= 2 %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to cast_booths_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-cast" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">ブース一覧</h5>
              <p class="card-text mb-0">操作対象のブースを選択します</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if current_user.at_least?(:cast) %>
      <div class="col-12 col-md-6 col-xl-4">
        <% if booth.present? %>
          <%= link_to cast_booth_path(booth), class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-cast" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">ブース情報</h5>
                <p class="card-text mb-0">ブースの詳細を確認できます。ブースURLの共有を行うことができます</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_cast_booths_path(return_to_key: "booth_show"),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-cast" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">ブース情報</h5>
                <p class="card-text mb-0">ブースの詳細を確認できます。ブースURLの共有を行うことができます</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if booth.present? %>
          <%= link_to edit_cast_booth_path(booth), class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-cast" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">ブース編集</h5>
                <p class="card-text mb-0">現在のブース設定を編集します</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_cast_booths_path(return_to_key: "booth_edit"),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-cast" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">ブース編集</h5>
                <p class="card-text mb-0">現在のブース設定を編集します</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if current_user.at_least?(:store_admin) && @selectable_stores_count >= 2 %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to admin_stores_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">店舗を選択</h5>
              <p class="card-text mb-0">操作対象の店舗を選択します</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if current_user.at_least?(:store_admin) %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to admin_booths_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">ブース管理</h5>
              <p class="card-text mb-0">ブースの作成・紐づけ・アーカイブを管理します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to edit_admin_store_path(store), class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗設定編集</h5>
                <p class="card-text mb-0">店舗情報を編集します</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to_key: "store_edit"),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗設定編集</h5>
                <p class="card-text mb-0">店舗情報を編集します</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_casts_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">キャスト一覧</h5>
                <p class="card-text mb-0">所属中キャストの確認と所属解除を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_casts_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">キャスト一覧</h5>
                <p class="card-text mb-0">所属中キャストの確認と所属解除を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_cast_invitations_path,
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin"
                data-bs-theme="light"
                data-onboarding-target-element="invite-cast-card">
              <div class="card-body">
                <h5 class="card-title mb-2">キャスト招待</h5>
                <p class="card-text mb-0">キャスト招待URLの発行と確認を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_cast_invitations_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">キャスト招待</h5>
                <p class="card-text mb-0">キャスト招待URLの発行と確認を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_store_admin_invitations_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗管理者招待</h5>
                <p class="card-text mb-0">店舗管理者招待URLの発行と確認を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_store_admin_invitations_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗管理者招待</h5>
                <p class="card-text mb-0">店舗管理者招待URLの発行と確認を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_cast_metrics_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">配信者別数値一覧</h5>
                <p class="card-text mb-0">配信者ごとの売上等を確認します</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_cast_metrics_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">配信者別数値一覧</h5>
                <p class="card-text mb-0">配信者ごとの売上等を確認します</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_drink_items_path,
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin"
                data-bs-theme="light"
                data-onboarding-target-element="setup-drinks-card">
              <div class="card-body">
                <h5 class="card-title mb-2">ドリンクメニュー</h5>
                <p class="card-text mb-0">ドリンクメニューを管理します</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_drink_items_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">ドリンクメニュー</h5>
                <p class="card-text mb-0">ドリンクメニューを管理します</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_comment_reports_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">通報一覧</h5>
                <p class="card-text mb-0">コメント通報の確認を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_comment_reports_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">通報一覧</h5>
                <p class="card-text mb-0">コメント通報の確認を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_store_bans_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗BAN</h5>
                <p class="card-text mb-0">ユーザーのBAN管理を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_store_bans_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">店舗BAN</h5>
                <p class="card-text mb-0">ユーザーのBAN管理を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to edit_admin_payout_account_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">
                  精算・振込設定
                  <% if store.payout_account_unconfigured? %>
                    <span class="badge text-bg-warning ms-2">未設定</span>
                  <% end %>
                </h5>
                <p class="card-text mb-0">振込先や精算設定を行います</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to_key: "payout_account_edit"),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">精算・振込設定</h5>
                <p class="card-text mb-0">振込先や精算設定を行います</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <% if store.present? %>
          <%= link_to admin_settlements_path, class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">精算（予定・履歴）</h5>
                <p class="card-text mb-0">精算の予定・履歴を確認します</p>
              </div>
            </div>
          <% end %>
        <% else %>
          <%= link_to select_modal_admin_stores_path(return_to: admin_settlements_path),
                      data: { turbo_frame: "modal" },
                      class: "text-decoration-none" do %>
            <div class="card h-100 dashboard-role-card dashboard-role-card-store-admin" data-bs-theme="light">
              <div class="card-body">
                <h5 class="card-title mb-2">精算（予定・履歴）</h5>
                <p class="card-text mb-0">精算の予定・履歴を確認します</p>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <% if current_user.system_admin? %>
      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to system_admin_users_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">ユーザー管理</h5>
              <p class="card-text mb-0">ユーザー情報を管理します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to system_admin_referral_codes_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">紹介コード管理</h5>
              <p class="card-text mb-0">紹介コードを管理します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to "/system_admin/settlements/manual/new", class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">マニュアル精算（テスト）</h5>
              <p class="card-text mb-0">手動で精算データを作成します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to system_admin_settlement_exports_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">振込CSV（住信SBI）</h5>
              <p class="card-text mb-0">振込用CSVを出力します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to system_admin_settlements_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">精算一覧</h5>
              <p class="card-text mb-0">精算データを確認します</p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-12 col-md-6 col-xl-4">
        <%= link_to system_admin_effects_path, class: "text-decoration-none" do %>
          <div class="card h-100 dashboard-role-card dashboard-role-card-system-admin" data-bs-theme="light">
            <div class="card-body">
              <h5 class="card-title mb-2">Effect管理</h5>
              <p class="card-text mb-0">Effectを管理します</p>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
