<% user = stream_session.started_by_cast_user %>
<% title_display = stream_session.title.presence || stream_session.booth.name %>

<div class="live-meta-row viewer-meta-row">
  <% if stream_session.booth.live? || stream_session.booth.away? %>
    <div class="meta-live-badge">
      <%= booth_status_badge(stream_session.booth) %>
    </div>
  <% end %>

  <!-- avatar -->
  <div class="meta-avatar">
    <%= user_avatar_badge(user, size: 28) %>
  </div>

  <!-- name -->
  <div class="meta-name">
    <%= link_to display_name_or_anonymous(user),
          user_path(user),
          class: "text-decoration-none text-reset" %>
  </div>

  <!-- title -->
  <div class="meta-title text-truncate">
    <%= title_display %>
  </div>

  <!-- viewer count -->
  <div class="meta-count">
    <i class="bi bi-people-fill" aria-hidden="true"></i>
    <span data-presence-poll-target="count">-</span>
  </div>
</div>
