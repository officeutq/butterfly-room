<%# locals: stream_session:, booth:, comments:, drink_items:, can_create_drink_order: %>

<% live_like = booth.live? || booth.away? %>
<% drink_menu_button_visible = live_like && Array(drink_items).any? %>

<div
  class="ivs-viewer-root"
  data-controller="ivs-viewer"
  data-ivs-viewer-token-url-value="<%= stream_session_ivs_participant_tokens_path(stream_session) %>"
>
  <video
    class="ivs-viewer-video"
    playsinline
    autoplay
    data-ivs-viewer-target="video"
  ></video>

  <div id="viewer_overlay">
    <div
      class="viewer-overlay-ui"
      data-controller="viewer-drink-panel"
      data-viewer-drink-panel-menu-url-value="<%= viewer_drink_menu_booth_path(booth) %>"
      data-viewer-grid-debug="<%= Rails.env.development? ? "1" : "0" %>">
      <div class="viewer-overlay-meta-slot">
        <div
          class="viewer-meta-panel"
          data-controller="presence-poll"
          data-presence-poll-ping-url-value="<%= ping_stream_session_presence_path(stream_session) %>"
          data-presence-poll-summary-url-value="<%= presence_summary_stream_session_path(stream_session) %>"
          data-presence-poll-interval-ms-value="20000"
        >
          <div class="viewer-meta-layout">
            <div class="viewer-meta-main">
              <%= render "stream_sessions/stream_meta_display",
                        stream_session: stream_session %>
            </div>

            <div class="viewer-meta-side">
              <div class="viewer-meta-viewer-count">
                <i class="bi bi-people-fill" aria-hidden="true"></i>
                <span data-presence-poll-target="count">-</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="viewer-overlay-main-row">
        <div class="viewer-overlay-main-spacer">
          <span class="viewer-slot-label">main spacer</span>
        </div>

        <div class="viewer-overlay-drink-slot">
          <div class="viewer-drink-panel">
            <div class="viewer-drink-panel-body">
              <%= render "stream_sessions/pending_drink_orders", stream_session: stream_session %>
            </div>
          </div>
        </div>
      </div>

      <div class="viewer-overlay-view-row"></div>

      <div class="viewer-overlay-bottom-row">
        <div class="viewer-overlay-comment-slot">
          <%= render "booths/comment_section",
                booth: booth,
                stream_session: stream_session,
                comments: comments %>
        </div>

        <div class="viewer-overlay-ops-slot">
          <div class="viewer-ops-panel">
            <div class="viewer-ops-buttons">
              <% if drink_menu_button_visible %>
                <button
                  type="button"
                  class="viewer-ops-btn"
                  data-action="viewer-drink-panel#toggle"
                  data-viewer-drink-panel-target="openButton"
                  aria-label="ドリンクメニューを開く"
                  aria-expanded="false"
                  aria-controls="viewer_drink_menu_panel"
                  title="ドリンクメニュー">
                  <i class="bi bi-cup-straw" aria-hidden="true"></i>
                </button>
              <% end %>

              <button
                type="button"
                class="viewer-ops-btn"
                data-action="ivs-viewer#toggleMute"
                data-ivs-viewer-target="muteButton"
                aria-label="ミュートを切り替える"
                title="ミュート切替"
              >
                <i
                  class="bi bi-volume-mute-fill"
                  data-ivs-viewer-target="muteIcon"
                  aria-hidden="true"
                ></i>
              </button>

              <div
                class="viewer-mute-hint"
                data-ivs-viewer-target="muteHint"
                style="display: none;"
              >
                タップで音を出せます
              </div>

              <div class="viewer-error-text" data-ivs-viewer-target="error"></div>
            </div>
          </div>
        </div>
      </div>

      <% if drink_menu_button_visible %>
        <%= render "booths/drink_menu_panel" %>
      <% end %>
    </div>
  </div>
</div>
