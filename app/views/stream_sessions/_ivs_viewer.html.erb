<div
  class="ivs-viewer-root"
  data-controller="ivs-viewer"
  data-ivs-viewer-token-url-value="<%= stream_session_ivs_participant_tokens_path(stream_session) %>"
>
  <video
    class="ivs-viewer-video"
    playsinline
    autoplay
    data-ivs-viewer-target="video"
  ></video>

  <div class="viewer-legacy-offscreen" aria-hidden="true">
    <div class="card">
      <div class="card-header">
        視聴
        <span class="ms-2 text-muted small" data-ivs-viewer-target="state">idle</span>
      </div>

      <div class="card-body">
        <div class="position-absolute top-0 start-0 m-2">
          <button
            type="button"
            class="btn btn-dark btn-sm"
            data-action="ivs-viewer#toggleMute"
            data-ivs-viewer-target="muteButton"
            aria-label="ミュート切替"
          >
            🔇
          </button>

          <div
            class="small mt-1 text-white-50"
            data-ivs-viewer-target="muteHint"
            style="display: none;"
          >
            タップで音を出せます
          </div>
        </div>

        <div class="mt-2 text-danger small" data-ivs-viewer-target="error"></div>
      </div>
    </div>
  </div>
</div>
