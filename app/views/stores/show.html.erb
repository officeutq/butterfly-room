<div class="container mt-4" style="max-width: 960px;">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div>
      <h1 class="mb-1"><%= @store.name %></h1>
      <p class="text-muted mb-0">店舗詳細</p>
    </div>

    <div id="store_favorite_button">
      <%= render "favorites/stores/button_store_show", store: @store, favorited: @store_favorited %>
    </div>
  </div>

  <hr class="my-4">

  <h2 class="h5 mb-3">店舗プロフィール</h2>

  <div class="mb-4">
    <% if @store.thumbnail.attached? %>
      <div class="mb-3">
        <%= image_tag @store.thumbnail, style: "max-width: 240px; height: auto;" %>
      </div>
    <% end %>

    <dl class="row mb-0">
      <dt class="col-sm-3 text-muted">概要</dt>
      <dd class="col-sm-9"><%= @store.description.presence || "-" %></dd>

      <dt class="col-sm-3 text-muted">地域</dt>
      <dd class="col-sm-9"><%= @store.area.presence || "-" %></dd>

      <dt class="col-sm-3 text-muted">業態</dt>
      <dd class="col-sm-9">
        <% if @store.business_type.present? %>
          <%= Store::BUSINESS_TYPE_LABELS[@store.business_type.to_sym] || @store.business_type %>
        <% else %>
          -
        <% end %>
      </dd>
    </dl>
  </div>

  <h2 class="h5 mb-3">ブース一覧</h2>

  <% if @booths.blank? %>
    <div class="alert alert-warning" role="alert">
      公開中のブースがありません。
    </div>
  <% else %>
    <div class="list-group">
      <% @booths.each do |booth| %>
        <div class="list-group-item">
          <div class="d-flex justify-content-between align-items-center gap-3">
            <div class="flex-grow-1">
              <div class="d-flex align-items-center gap-2">
                <strong><%= booth.name %></strong>

                <%# 任意：状態バッジ（最小） %>
                <% if booth.live? %>
                  <span class="badge text-bg-danger">LIVE</span>
                <% elsif booth.standby? %>
                  <span class="badge text-bg-success">STANDBY</span>
                <% elsif booth.away? %>
                  <span class="badge text-bg-warning">AWAY</span>
                <% else %>
                  <span class="badge text-bg-secondary">OFFLINE</span>
                <% end %>
              </div>

              <% casts = booth.cast_users.to_a %>
              <% if casts.present? %>
                <div class="text-muted small mt-1">
                  cast:
                  <%= casts.map { |u| u.display_name.presence || u.email }.join(" / ") %>
                </div>
              <% else %>
                <div class="text-muted small mt-1">cast: (未設定)</div>
              <% end %>
            </div>

            <div class="text-end">
              <% open_in_modal =
                   user_signed_in? && (
                     current_user.system_admin? ||
                     (current_user.store_admin? && current_user.admin_of_store?(@store.id))
                   ) %>

              <%= button_to "視聴ページへ",
                    enter_booth_path(booth),
                    method: :get,
                    class: "btn btn-outline-primary btn-sm",
                    form: {
                      class: "d-inline",
                      data: (
                        (open_in_modal ? { turbo_frame: "modal" } : {})
                          .merge(turbo_confirm: enter_booth_switch_confirm_message(booth))
                      )
                    } %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-4">
    <%= link_to "戻る", root_path, class: "btn btn-outline-secondary" %>
  </div>
</div>
