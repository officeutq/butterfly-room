<%# locals: booth:, favorited: %>

<% if favorited %>
  <%= button_to "お気に入り解除",
        booth_favorite_path(booth),
        method: :delete,
        class: "btn btn-sm btn-outline-secondary" %>
<% else %>
  <%= button_to "お気に入り",
        booth_favorite_path(booth),
        method: :post,
        class: "btn btn-sm btn-outline-primary" %>
<% end %>
