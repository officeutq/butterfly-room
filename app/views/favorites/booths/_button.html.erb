<%# locals: booth:, favorited: %>

<% if favorited %>
  <%= button_to booth_favorite_path(booth),
        method: :delete,
        class: "viewer-favorite-btn is-active",
        form_class: "viewer-favorite-form",
        aria: { label: "ブースのお気に入りを解除" },
        title: "お気に入り解除",
        data: {
          controller: "favorite-sync",
          favorite_sync_key_value: "booth-#{booth.id}",
          favorite_sync_active_value: true,
          favorite_sync_active_title_value: "お気に入り解除",
          favorite_sync_inactive_title_value: "お気に入り",
          favorite_sync_active_aria_label_value: "ブースのお気に入りを解除",
          favorite_sync_inactive_aria_label_value: "ブースをお気に入り"
        } do %>
    <i class="bi bi-star-fill" aria-hidden="true"></i>
  <% end %>
<% else %>
  <%= button_to booth_favorite_path(booth),
        method: :post,
        class: "viewer-favorite-btn",
        form_class: "viewer-favorite-form",
        aria: { label: "ブースをお気に入り" },
        title: "お気に入り",
        data: {
          controller: "favorite-sync",
          favorite_sync_key_value: "booth-#{booth.id}",
          favorite_sync_active_value: false,
          favorite_sync_active_title_value: "お気に入り解除",
          favorite_sync_inactive_title_value: "お気に入り",
          favorite_sync_active_aria_label_value: "ブースのお気に入りを解除",
          favorite_sync_inactive_aria_label_value: "ブースをお気に入り"
        } do %>
    <i class="bi bi-star" aria-hidden="true"></i>
  <% end %>
<% end %>
