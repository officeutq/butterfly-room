<div style="max-width: 960px;">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div>
      <h1 class="mb-1">お気に入りブース</h1>
      <p class="text-muted mb-0">新しい順</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "店舗のお気に入り", favorites_stores_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <hr class="my-4">

  <% if @favorite_booths.blank? %>
    <div class="alert alert-secondary" role="alert">
      お気に入りブースはありません。
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      <% @favorite_booths.each do |favorite| %>
        <% booth = favorite.booth %>

        <div class="col">
          <%= render "booths/card",
                booth: booth,
                booth_favorited: true,
                store_favorited: @favorite_store_ids.include?(booth.store_id) %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
