<div style="max-width: 960px;">
  <div class="d-flex flex-column gap-3 mb-3">
    <div class="btn-group" role="group" aria-label="お気に入り表示切り替え">
      <%= link_to "ブース",
            favorites_booths_path,
            class: "btn btn-secondary active",
            "aria-current": "page" %>

      <%= link_to "店舗",
            favorites_stores_path,
            class: "btn btn-outline-secondary" %>
    </div>
  </div>

  <% if @favorite_booths.blank? %>
    <div class="alert alert-secondary" role="alert">
      お気に入りブースはありません。
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      <% @favorite_booths.each do |favorite| %>
        <% booth = favorite.booth %>

        <div class="col">
          <%= render "booths/card",
                booth: booth,
                booth_favorited: true,
                store_favorited: @favorite_store_ids.include?(booth.store_id) %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
