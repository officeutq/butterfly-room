<% content_for :title, "お気に入り" %>
<% content_for :fixed_subnav_body_class, "page-with-fixed-subnav" %>

<% content_for :fixed_subnav do %>
  <div class="fixed-subnav">
    <div class="container py-2">
      <%= render "favorites/nav" %>
    </div>
  </div>
<% end %>

<div style="max-width: 960px;">
  <% if @favorite_stores.blank? %>
    <div class="alert alert-secondary" role="alert">
      お気に入り店舗はありません。
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      <% @favorite_stores.each do |favorite| %>
        <% store = favorite.store %>

        <div class="col">
          <%= render "stores/card", store: store, favorited: true %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
