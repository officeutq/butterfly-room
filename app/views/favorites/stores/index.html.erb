<div style="max-width: 960px;">
  <div class="d-flex justify-content-between align-items-start gap-3">
    <div>
      <h1 class="mb-1">お気に入り店舗</h1>
      <p class="text-muted mb-0">新しい順</p>
    </div>

    <div class="d-flex gap-2">
      <%= link_to "ブースのお気に入り", favorites_booths_path, class: "btn btn-outline-secondary btn-sm" %>
    </div>
  </div>

  <hr class="my-4">

  <% if @favorite_stores.blank? %>
    <div class="alert alert-secondary" role="alert">
      お気に入り店舗はありません。
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-3">
      <% @favorite_stores.each do |favorite| %>
        <% store = favorite.store %>

        <div class="col">
          <%= render "stores/card", store: store, favorited: true %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
