<%# locals: booth:, stream_session: %>
<turbo-frame id="modal">
  <div class="modal fade" tabindex="-1" aria-labelledby="standbyMetaModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h1 class="modal-title fs-5" id="standbyMetaModalLabel">配信設定</h1>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="閉じる"></button>
        </div>

        <%= form_with model: stream_session,
                      url: metadata_cast_stream_session_path(stream_session),
                      method: :patch,
                      data: { action: "turbo:submit-end->modal#submitEnd" } do |f| %>
          <div class="modal-body">
            <div class="mb-3">
              <%= f.label :title, "タイトル", class: "form-label" %>
              <%= f.text_field :title,
                               class: "form-control",
                               maxlength: 64,
                               placeholder: "未入力ならブース名が表示されます" %>
              <div class="form-text">最大64文字</div>
            </div>

            <div class="mb-0">
              <%= f.label :description, "説明", class: "form-label" %>
              <%= f.text_area :description,
                              class: "form-control",
                              maxlength: 256,
                              rows: 4 %>
              <div class="form-text">最大256文字（未入力なら非表示）</div>
            </div>
          </div>

          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">閉じる</button>
            <%= f.submit "保存する", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</turbo-frame>
