<div
  class="live-effect-overlay d-none"
  data-action="click->ivs-publisher#closeEffectPanelOnBackdrop"
  data-ivs-publisher-target="effectOverlay">
  <div
    class="live-effect-panel"
    data-ivs-publisher-target="effectPanel">
    <div class="live-panel-header">
      <div class="live-panel-header-text">
        <div class="live-effect-panel-title">加工モード</div>
        <div class="live-effect-panel-caption">Beauty と Effect は単一選択です</div>
      </div>

      <button type="button"
              class="live-panel-close-btn"
              data-action="ivs-publisher#closeEffectPanel"
              aria-label="加工モード選択を閉じる"
              title="閉じる">
        <i class="bi bi-x-lg" aria-hidden="true"></i>
      </button>
    </div>

    <div class="live-effect-toggle-group" role="radiogroup" aria-label="加工モード選択">
      <input
        type="radio"
        class="btn-check"
        name="cast_live_effect_mode"
        id="cast_live_effect_mode_none"
        value="none"
        autocomplete="off"
        data-action="change->ivs-publisher#onEffectSelectionChanged">

      <label class="btn btn-outline-light live-effect-toggle-btn" for="cast_live_effect_mode_none">
        なし
      </label>

      <input
        type="radio"
        class="btn-check"
        name="cast_live_effect_mode"
        id="cast_live_effect_mode_beauty"
        value="beauty"
        autocomplete="off"
        checked
        data-action="change->ivs-publisher#onEffectSelectionChanged">

      <label class="btn btn-outline-light live-effect-toggle-btn" for="cast_live_effect_mode_beauty">
        Beauty
      </label>

      <% Array(effects).each do |effect| %>
        <% input_id = "cast_live_effect_mode_#{effect.key.to_s.parameterize(separator: "_")}" %>

        <input
          type="radio"
          class="btn-check"
          name="cast_live_effect_mode"
          id="<%= input_id %>"
          value="<%= effect.key %>"
          data-effect-zip-filename="<%= effect.zip_filename %>"
          autocomplete="off"
          data-action="change->ivs-publisher#onEffectSelectionChanged">

        <label class="btn btn-outline-light live-effect-toggle-btn" for="<%= input_id %>">
          <% if effect.icon_path.present? %>
            <%= image_tag effect.icon_path,
                          class: "live-effect-toggle-icon",
                          alt: effect.name %>
            <span class="visually-hidden"><%= effect.name %></span>
          <% else %>
            <%= effect.name %>
          <% end %>
        </label>
      <% end %>
    </div>
  </div>
</div>
