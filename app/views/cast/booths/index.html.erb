<% content_for :title, "ブース一覧" %>

<div class="mb-4 d-flex gap-2 align-items-center flex-wrap">
  <% if @include_archived %>
    <%= link_to "現役のみ表示", cast_booths_path, class: "btn btn-outline-secondary" %>
  <% else %>
    <%= link_to "閉鎖済みも表示", cast_booths_path(archived: 1), class: "btn btn-outline-secondary" %>
  <% end %>
</div>

<% if @booths.blank? %>
  <div class="alert alert-warning" role="alert">
    操作可能なブースがありません。
  </div>
<% else %>
  <div class="row g-4">
    <% @booths.each do |booth| %>
      <% current_selected = booth.id.to_s == @current_booth_id.to_s %>
      <% archived = booth.archived? %>
      <% switch_form_data = {} %>

      <% if @confirm_switch_booth && !current_selected && !archived %>
        <% switch_form_data[:turbo_confirm] = enter_booth_switch_confirm_message(booth) %>
      <% end %>

      <div class="col-12 col-lg-6 col-xxl-4">
        <div class="card h-100 cast-booths-card <%= "is-archived" if archived %>" data-bs-theme="light">
          <div class="ratio ratio-16x9 border-bottom cast-booths-card-thumbnail-wrap">
            <% if booth.thumbnail_image.attached? %>
              <%= image_tag booth.thumbnail_image,
                    class: "w-100 h-100 cast-booths-card-thumbnail",
                    style: "object-fit: cover;",
                    alt: booth.name.presence || "(no name)" %>
            <% else %>
              <div class="d-flex align-items-center justify-content-center bg-body-tertiary cast-booths-card-thumbnail">
                <div class="text-center text-muted">
                  <div class="fs-1 lh-1">
                    <i class="bi bi-camera-video"></i>
                  </div>
                  <div class="small mt-2">サムネイル未設定</div>
                </div>
              </div>
            <% end %>

            <div class="cast-booths-card-overlay">
              <div class="cast-booths-card-overlay-left">
                <% if !archived && !current_selected %>
                  <%= button_to "このブースへ切り替え",
                        cast_current_booth_path,
                        method: :post,
                        params: {
                          booth_id: booth.id,
                          return_to: (@include_archived ? cast_booths_path(archived: 1) : cast_booths_path)
                        },
                        class: "btn btn-warning btn-sm",
                        form: {
                          class: "d-inline cast-booths-card-switch-form",
                          data: switch_form_data
                        } %>
                <% end %>
              </div>

              <div class="cast-booths-card-overlay-right">
                <% if current_selected %>
                  <span class="badge text-bg-success cast-booths-card-badge">選択中</span>
                <% end %>
              </div>
            </div>
          </div>

          <div class="card-body d-flex flex-column">
            <div class="cast-booths-card-title-row">
              <div class="cast-booths-card-title">
                <h2 class="h5 mb-0 cast-booths-card-title-text"><%= booth.name.presence || "(no name)" %></h2>
              </div>

              <div class="cast-booths-card-status d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <%= booth_status_badge(booth) %>

                <% if archived %>
                  <span class="badge text-bg-dark">閉鎖済み</span>
                <% end %>
              </div>
            </div>
            <% if !archived %>
              <div class="mt-auto cast-booths-card-actions pt-3">
                <%= link_to "配信",
                      enter_booth_path(booth),
                      class: "btn btn-primary btn-sm" %>

                <%= link_to "このブースを選択して編集",
                      edit_cast_booth_path(booth),
                      class: "btn btn-outline-secondary btn-sm" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
