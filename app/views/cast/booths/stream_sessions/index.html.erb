<% content_for :title, "配信履歴" %>

<div class="mb-4">
  <div class="text-muted small"><%= @booth.store.name %></div>
  <h1 class="h4 fw-bold mb-0"><%= @booth.name.presence || "(no name)" %></h1>
</div>

<% if @stream_sessions.blank? %>
  <div class="alert alert-warning" role="alert">
    配信履歴はまだありません。
  </div>
<% else %>
  <div class="row g-4">
    <% @stream_sessions.each do |stream_session| %>
      <% duration_seconds = stream_session.broadcast_duration_seconds %>
      <% hours = duration_seconds / 3600 %>
      <% minutes = (duration_seconds % 3600) / 60 %>
      <% seconds = duration_seconds % 60 %>

      <div class="col-12 col-lg-6 col-xxl-4">
        <%= link_to cast_stream_session_path(stream_session), class: "text-decoration-none text-reset" do %>
          <div class="card h-100" data-bs-theme="light">
            <div class="card-body d-flex flex-column">
              <div>
                <div class="d-flex flex-column gap-2 small">
                  <div>
                    <span class="text-body-secondary">配信タイトル：</span>
                    <%= stream_session.title.presence || @booth.name.presence || "(no title)" %>
                  </div>

                  <div>
                    <span class="text-body-secondary">配信者：</span>
                    <%= user_avatar_badge(stream_session.started_by_cast_user, size: 28) %>&nbsp;<%= display_name_or_anonymous(stream_session.started_by_cast_user) %>
                  </div>

                  <div>
                    <span class="text-body-secondary">配信開始：</span>
                    <%= stream_session.broadcast_started_at.present? ? l(stream_session.broadcast_started_at, format: :long) : "-" %>
                  </div>

                  <div>
                    <span class="text-body-secondary">配信時間：</span>
                    <%= format("%02d:%02d:%02d", hours, minutes, seconds) %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>
