<div
  class="cast-live-screen"
  data-controller="ivs-publisher live-stage"
  data-ivs-publisher-token-url-value="<%= stream_session_ivs_participant_tokens_path(@stream_session) %>"
  data-ivs-publisher-finish-url-value="<%= finish_cast_stream_session_path(@stream_session) %>"
  data-ivs-publisher-status-url-value="<%= status_cast_booth_path(@booth) %>"
  data-ivs-publisher-meta-display-url-value="<%= meta_display_cast_stream_session_path(@stream_session) %>"
  data-ivs-publisher-mirror-value="true"
  data-ivs-publisher-initial-mode-value="<%= @booth.away? ? "away" : "normal" %>"
  data-ivs-publisher-initial-booth-status-value="<%= @booth.status %>"
  data-ivs-publisher-banuba-client-token-value="<%= @banuba_client_token %>"
  data-ivs-publisher-banuba-sdk-base-url-value="<%= @banuba_sdk_base_url %>"
  data-ivs-publisher-banuba-face-tracker-url-value="<%= @banuba_face_tracker_url %>"
  data-ivs-publisher-banuba-eyes-url-value="<%= @banuba_eyes_url %>"
  data-ivs-publisher-banuba-lips-url-value="<%= @banuba_lips_url %>"
  data-ivs-publisher-banuba-skin-url-value="<%= @banuba_skin_url %>"
  data-ivs-publisher-banuba-background-url-value="<%= @banuba_background_url %>"
  data-ivs-publisher-banuba-hair-url-value="<%= @banuba_hair_url %>"
  data-ivs-publisher-banuba-effect-url-value="<%= @banuba_effect_url %>"
  data-ivs-publisher-banuba-effect-name-value="<%= @banuba_effect_name %>"
  data-ivs-publisher-banuba-beauty-config-url-value="/banuba/effects/beauty_base/config.json"
>
  <div id="live_stage">
    <div id="live_media">
      <div
        class="live-banuba-surface"
        data-ivs-publisher-target="banubaSurface"></div>

      <canvas
        class="d-none"
        data-ivs-publisher-target="canvas"></canvas>
    </div>

    <div id="live_flash_layer">
      <div id="flash_inner">
        <% if notice.present? %>
          <%= render "shared/flash_message", level: "success", message: notice %>
        <% end %>

        <% if alert.present? %>
          <%= render "shared/flash_message", level: "danger", message: alert %>
        <% end %>
      </div>
    </div>

    <div id="live_overlay">
      <div class="live-overlay-ui" data-live-grid-debug="<%= Rails.env.development? ? "1" : "0" %>">
        <div class="live-overlay-meta-slot">
          <div
            class="live-meta-panel d-none"
            data-controller="presence-poll"
            data-ivs-publisher-target="metaPanel"
            data-presence-poll-summary-url-value="<%= presence_summary_stream_session_path(@stream_session) %>"
            data-presence-poll-interval-ms-value="20000"
          >
            <turbo-frame id="stream_meta_display">
              <%= render "stream_sessions/stream_meta_display",
                        stream_session: @stream_session %>
            </turbo-frame>
          </div>
        </div>

        <div class="live-overlay-main-row">
          <div class="live-overlay-main-spacer"></div>

          <div class="live-overlay-drink-slot">
            <%= turbo_stream_from [@stream_session, :cast_pending_drink_orders] %>

            <div class="live-drink-panel d-none" data-ivs-publisher-target="drinkPanel">
              <div class="live-drink-panel-body">
                <div id="cast-pending-drink-orders-container">
                  <%= render "cast/stream_sessions/pending_drink_orders", stream_session: @stream_session %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="live-overlay-bottom-row">
          <div class="live-overlay-comment-slot">
            <%= turbo_stream_from [@stream_session, :comments] %>

            <div class="live-comment-stack">
              <div id="cast_comment_section">
                <%= render "cast/booths/comment_section",
                          booth: @booth,
                          stream_session: @stream_session,
                          comments: @comments %>
              </div>

              <% if @booth.standby? && @booth.current_stream_session_id == @stream_session.id %>
                <div id="cast_title_section">
                  <div class="live-comment-panel" data-ivs-publisher-target="summaryPanel">
                    <div class="live-comment-form">
                      <%= form_with model: @stream_session,
                                    url: metadata_cast_stream_session_path(@stream_session),
                                    method: :patch,
                                    class: "live-standby-actions-form" do |f| %>
                        <div class="input-group">
                          <span class="input-group-text">配信タイトル</span>
                          <%= f.text_field :title,
                                          class: "form-control",
                                          maxlength: 64,
                                          placeholder: "未入力ならブース名が表示されます",
                                          aria: { label: "タイトル" },
                                          data: { keyboard_role: "title" } %>
                          <%= f.submit "設定", class: "btn btn-primary" %>
                        </div>
                      <% end %>
                    </div>
                  </div>
                </div>
              <% end %>
            </div>
          </div>

          <div class="live-overlay-ops-slot">
            <div class="live-ops-panel d-none" data-ivs-publisher-target="opsPanel">
              <div class="live-ops-buttons">
                <%= form_with url: status_cast_booth_path(@booth, to: :away),
                              method: :patch,
                              class: "live-ops-form",
                              data: { action: "turbo:submit-end->ivs-publisher#onBoothStatusPatched" } do %>
                  <button type="submit"
                          class="live-ops-btn"
                          data-ivs-publisher-target="cameraOffBtn"
                          aria-label="カメラをオフにする"
                          title="カメラON">
                    <i class="bi bi-camera-video-fill" aria-hidden="true"></i>
                  </button>
                <% end %>

                <%= form_with url: status_cast_booth_path(@booth, to: :live),
                              method: :patch,
                              class: "live-ops-form",
                              data: { action: "turbo:submit-end->ivs-publisher#onBoothStatusPatched" } do %>
                  <button type="submit"
                          class="live-ops-btn"
                          data-ivs-publisher-target="cameraOnBtn"
                          aria-label="カメラをオンにする"
                          title="カメラOFF">
                    <i class="bi bi-camera-video-off-fill" aria-hidden="true"></i>
                  </button>
                <% end %>

                <button type="button"
                        class="live-ops-btn"
                        data-action="ivs-publisher#toggleMic"
                        data-ivs-publisher-target="micBtn"
                        aria-label="マイクを切り替える"
                        title="マイク切替">
                  <i class="bi bi-mic-fill" data-ivs-publisher-target="micIcon" aria-hidden="true"></i>
                </button>

                <button type="button"
                        class="live-ops-btn"
                        data-action="ivs-publisher#openEffectPanel"
                        data-ivs-publisher-target="effectOpenBtn"
                        aria-label="加工モードを選択する"
                        title="加工モード選択">
                  <i class="bi bi-stars" aria-hidden="true"></i>
                </button>

                <button type="button"
                        class="live-ops-btn d-none"
                        data-action="ivs-publisher#openBeautyPanel"
                        data-ivs-publisher-target="beautyAdjustBtn"
                        aria-label="Beauty 設定を開く"
                        title="Beauty 調整">
                  <i class="bi bi-sliders" aria-hidden="true"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <%= render "cast/booths/effect_panel", effects: @effects %>
    <%= render "cast/booths/beauty_panel" %>
  </div>

  <footer id="app_footer" class="cast-live-footer border-top bg-white fixed-bottom">
    <div class="container-fluid app-footer-shell">
      <div class="container">
        <nav class="app-footer-nav app-footer-nav--5" aria-label="配信画面フッターナビゲーション">
          <%= link_to root_path, class: footer_nav_item_classes do %>
            <i class="bi bi-house-fill app-footer-nav-icon" aria-hidden="true"></i>
            <span class="app-footer-nav-label">ホーム</span>
          <% end %>

          <%= link_to favorites_booths_path, class: footer_nav_item_classes do %>
            <i class="bi bi-star-fill app-footer-nav-icon" aria-hidden="true"></i>
            <span class="app-footer-nav-label">お気に入り</span>
          <% end %>

          <div class="app-footer-nav-slot app-footer-nav-slot--center">
            <button type="button"
                    class="app-footer-nav-item app-footer-nav-item--live app-footer-nav-item--live-start"
                    data-action="ivs-publisher#startBroadcast"
                    data-ivs-publisher-target="startBtn"
                    data-label-normal="配信開始"
                    data-label-resume="配信に戻る">
              <i class="bi bi-record-fill app-footer-nav-icon" aria-hidden="true"></i>
              <span class="app-footer-nav-label">配信開始</span>
            </button>

            <button type="button"
                    class="app-footer-nav-item app-footer-nav-item--live app-footer-nav-item--live-end d-none"
                    data-action="ivs-publisher#endBroadcast"
                    data-ivs-publisher-target="endBtn">
              <i class="bi bi-stop-fill app-footer-nav-icon" aria-hidden="true"></i>
              <span class="app-footer-nav-label">配信終了</span>
            </button>
          </div>

          <div class="<%= footer_nav_item_classes(extra: 'app-footer-nav-item--placeholder') %>" aria-disabled="true">
            <i class="bi bi-bell-fill app-footer-nav-icon" aria-hidden="true"></i>
            <span class="app-footer-nav-label">お知らせ</span>
          </div>

          <%= link_to dashboard_path_for(current_user), class: footer_nav_item_classes do %>
            <i class="bi bi-list app-footer-nav-icon" aria-hidden="true"></i>
            <span class="app-footer-nav-label">ダッシュボード</span>
          <% end %>
        </nav>
      </div>
    </div>
  </footer>
</div>
