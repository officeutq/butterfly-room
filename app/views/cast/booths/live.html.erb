<div
  data-controller="ivs-publisher live-stage"
  data-ivs-publisher-token-url-value="<%= stream_session_ivs_participant_tokens_path(@stream_session) %>"
  data-ivs-publisher-finish-url-value="<%= finish_cast_stream_session_path(@stream_session) %>"
  data-ivs-publisher-status-url-value="<%= status_cast_booth_path(@booth) %>"
  data-ivs-publisher-mirror-value="true"
  data-ivs-publisher-initial-mode-value="<%= @booth.away? ? "away" : "normal" %>"
  data-ivs-publisher-initial-booth-status-value="<%= @booth.status %>"
>
  <%# ------------------------------------------------------------
      Stage（映像 + Overlay）
      ------------------------------------------------------------ %>
  <div id="live_stage">
    <div id="live_media">
      <video
        playsinline
        autoplay
        muted
        data-ivs-publisher-target="preview"></video>

      <canvas
        class="d-none"
        width="1280" height="720"
        data-ivs-publisher-target="canvas"></canvas>
    </div>

    <%# ------------------------------------------------------------
        Overlay（映像上にDOMを重ねる）
        - Overlay自体は pointer-events:none
        - 実UIは .live-overlay-ui で pointer-events:auto
        ------------------------------------------------------------ %>
    <div id="live_overlay">
      <div class="live-overlay-ui" data-live-grid-debug="1">
        <div class="live-overlay-meta-slot">
          <div class="live-slot-label">meta slot</div>
        </div>

        <div class="live-overlay-main-row">
          <div class="live-overlay-main-spacer"></div>

          <div class="live-overlay-drink-slot">
            <%= turbo_stream_from [@stream_session, :cast_pending_drink_orders] %>

            <div class="live-drink-panel d-none" data-ivs-publisher-target="drinkPanel">
              <div class="live-drink-panel-header">ドリンク</div>

              <div class="live-drink-panel-body">
                <div id="cast-pending-drink-orders-container">
                  <%= render "cast/stream_sessions/pending_drink_orders", stream_session: @stream_session %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="live-overlay-bottom-row">
          <div class="live-overlay-comment-slot">
            <%= turbo_stream_from [@stream_session, :comments] %>

            <div id="cast_comment_section">
              <%= render "cast/booths/comment_section",
                        booth: @booth,
                        stream_session: @stream_session,
                        comments: @comments %>
            </div>
          </div>

          <div class="live-overlay-ops-slot">
            <div class="live-ops-panel d-none" data-ivs-publisher-target="opsPanel">
              <div class="live-ops-buttons">
                <%= form_with url: status_cast_booth_path(@booth, to: :away),
                              method: :patch,
                              class: "live-ops-form",
                              data: { action: "turbo:submit-end->ivs-publisher#onBoothStatusPatched" } do %>
                  <button type="submit"
                          class="live-ops-btn"
                          data-ivs-publisher-target="cameraOffBtn"
                          aria-label="カメラをオフにする"
                          title="カメラON">
                    <i class="bi bi-camera-video-fill" aria-hidden="true"></i>
                  </button>
                <% end %>

                <%= form_with url: status_cast_booth_path(@booth, to: :live),
                              method: :patch,
                              class: "live-ops-form",
                              data: { action: "turbo:submit-end->ivs-publisher#onBoothStatusPatched" } do %>
                  <button type="submit"
                          class="live-ops-btn"
                          data-ivs-publisher-target="cameraOnBtn"
                          aria-label="カメラをオンにする"
                          title="カメラOFF">
                    <i class="bi bi-camera-video-off-fill" aria-hidden="true"></i>
                  </button>
                <% end %>

                <button type="button"
                        class="live-ops-btn"
                        data-action="ivs-publisher#toggleMic"
                        data-ivs-publisher-target="micBtn"
                        aria-label="マイクを切り替える"
                        title="マイク切替">
                  <i class="bi bi-mic-fill" data-ivs-publisher-target="micIcon" aria-hidden="true"></i>
                </button>
              </div>
            </div>
          </div>
        </div>

        <%# --------------------------------------------------------
            既存UIは DOM を残したまま画面外へ退避
            -------------------------------------------------------- %>
        <div class="live-offscreen">
          <%# live は layout の Main が無いので、flash の箱だけはページ側に常設しておく %>
          <div id="flash_inner">
            <% if notice.present? %>
              <div class="alert alert-success" role="alert"><%= notice %></div>
            <% end %>
            <% if alert.present? %>
              <div class="alert alert-danger" role="alert"><%= alert %></div>
            <% end %>
          </div>

          <%# ---- 開発用テキスト（#317では残す） ---- %>
          <h1>Cast Booth（Live）</h1>

          <p>booth: <strong>#<%= @booth.id %> <%= @booth.name %></strong></p>
          <p>status: <strong><%= @booth.status %></strong></p>

          <%= render "cast/booths/stream_meta",
                     booth: @booth,
                     stream_session: @stream_session %>

          <div class="d-flex align-items-center gap-2 flex-wrap">
            <div class="fw-semibold">配信（Real-Time Stage）</div>
            <span class="text-muted small" data-ivs-publisher-target="state">idle</span>

            <% if @booth.standby? %>
              <%= button_to "サマリーへ戻る",
                    finish_cast_stream_session_path(@stream_session),
                    method: :post,
                    class: "btn btn-outline-secondary btn-sm",
                    data: { ivs_publisher_target: "summaryBtn" } %>
            <% end %>
          </div>

          <div class="mt-2 text-danger small"
               data-ivs-publisher-target="error"></div>

          <hr>

          <%# comments / drink / ops は Overlay 側へ移動したので、offscreen からは撤去（重複IDを避ける） %>
        </div>
      </div>
    </div>
  </div>

  <footer id="app_footer" class="border-top bg-white fixed-bottom">
    <div class="container py-2">
      <div class="d-flex justify-content-between align-items-center">
        <div class="d-flex gap-3">
          <%= link_to "ホーム", root_path, class: "btn btn-sm btn-outline-secondary" %>
          <%= link_to "お気に入り", favorites_booths_path, class: "btn btn-sm btn-outline-secondary" %>
        </div>

        <div class="d-flex gap-2">
          <button type="button"
                  class="btn btn-sm btn-primary"
                  data-action="ivs-publisher#startBroadcast"
                  data-ivs-publisher-target="startBtn"
                  data-label-normal="配信開始"
                  data-label-resume="配信に戻る">
            配信開始
          </button>

          <button type="button"
                  class="btn btn-sm btn-danger d-none"
                  data-action="ivs-publisher#endBroadcast"
                  data-ivs-publisher-target="endBtn">
            配信終了
          </button>
        </div>

        <div class="d-flex gap-2 align-items-center">
          <%= link_to "ダッシュボード",
                dashboard_path_for(current_user),
                class: "btn btn-sm btn-outline-secondary" %>

          <% if user_signed_in? %>
            <%= button_to "ログアウト",
                  destroy_user_session_path,
                  method: :delete,
                  class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
        </div>
      </div>
    </div>
  </footer>
</div>
