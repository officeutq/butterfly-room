<h1>ブース編集</h1>

<%= form_with model: [:cast, @booth] do |f| %>
  <% if @booth.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @booth.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :description, "説明文", class: "form-label" %>
    <%= f.text_area :description, class: "form-control", rows: 6 %>
  </div>

  <div class="mb-3">
    <%= f.label :thumbnail_image, "サムネ画像", class: "form-label" %>

    <% if @booth.thumbnail_image.attached? %>
      <div class="mb-2">
        <%= image_tag @booth.thumbnail_image, style: "max-width: 240px; height: auto;" %>
      </div>

      <div class="form-check mb-2">
        <%= check_box_tag "booth[remove_thumbnail_image]", "1", false,
                          class: "form-check-input", id: "remove_thumbnail_image" %>
        <%= label_tag "remove_thumbnail_image", "画像なし", class: "form-check-label" %>
      </div>
    <% end %>

    <%= f.file_field :thumbnail_image,
                    class: "form-control",
                    accept: "image/png,image/jpeg,image/webp" %>
    <div class="form-text">png / jpg / webp、最大 1024x1024 に縮小保存</div>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit "更新する", class: "btn btn-primary" %>
    <%= link_to "戻る", cast_booths_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
