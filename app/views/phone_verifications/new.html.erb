<% content_for :title, "電話番号認証" %>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="card" data-bs-theme="light">
      <div class="card-body">
        <h1 class="h4 mb-3">電話番号認証</h1>

        <% if @user.phone_verified? %>
          <div class="alert alert-success">
            現在の認証済み電話番号: <strong><%= @user.phone_number %></strong><br>
            認証日時: <%= l(@user.phone_verified_at) %>
          </div>
          <p class="text-muted">
            新しい電話番号を入力して認証すると、登録済み番号を上書きできます。
          </p>
        <% else %>
          <div class="alert alert-secondary">
            電話番号はまだ認証されていません。
          </div>
        <% end %>

        <%= form_with url: phone_verification_path, method: :post do %>
          <div class="mb-3">
            <%= label_tag :phone_number, "電話番号", class: "form-label" %>
            <%= telephone_field_tag :phone_number, @phone_number, class: "form-control", placeholder: "09012345678" %>
            <div class="form-text">入力した電話番号宛に認証コードを送信します。</div>
          </div>

          <div class="d-flex gap-2">
            <%= submit_tag "認証コードを送信", class: "btn btn-primary" %>
            <%= link_to "戻る", dashboard_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
