<div style="max-width: 720px;">
  <h1 class="h4 mb-3">store_admin 招待</h1>

  <div class="card mb-3">
    <div class="card-body">
      <div class="mb-2">
        <span class="text-muted">店舗：</span>
        <strong><%= @invitation.store.name %></strong>
      </div>

      <div class="mb-2">
        <span class="text-muted">期限：</span>
        <span><%= l(@invitation.expires_at) %></span>
      </div>

      <div class="mb-0">
        <span class="text-muted">状態：</span>
        <span><%= @invitation.status_label %></span>
      </div>
    </div>
  </div>

  <% if !user_signed_in? %>
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-2">store_admin 招待を受ける</h2>
        <p class="text-muted mb-3">
          この招待を受けるには store_admin アカウントが必要です。
        </p>

        <div class="d-grid gap-2">
          <%= link_to "新規 store_admin アカウントを作成して招待を受ける",
                store_admin_sign_up_path(token: params[:token]),
                class: "btn btn-primary" %>

          <%= link_to "既存の store_admin アカウントで招待を受ける",
                new_user_session_path(invite_token: params[:token], invite_kind: "store_admin"),
                class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>

  <% elsif !current_user.store_admin? %>
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-2">store_admin アカウントで招待を受けてください</h2>
        <p class="text-muted mb-3">
          この招待は store_admin アカウントでのみ承認できます。<br>
          現在は store_admin 以外のアカウントでログインしています。
        </p>

        <div class="d-grid gap-2 d-sm-flex">
          <%= button_to "ログアウトして store_admin アカウントでログインする",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-primary" %>

          <%= link_to "store_admin アカウントを新規作成する",
                store_admin_sign_up_path(token: params[:token]),
                class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>

  <% else %>
    <% if @already_member %>
      <div class="alert alert-success" role="alert">
        この店舗にはすでに store_admin として登録されています。
      </div>

      <div class="d-flex gap-2">
        <%= link_to "ダッシュボードへ", dashboard_path, class: "btn btn-outline-secondary" %>
      </div>

    <% elsif !@invitation.usable? %>
      <div class="alert alert-danger" role="alert">
        この招待は使用できません（期限切れ / 使用済み）。
      </div>

    <% else %>
      <div class="alert alert-info" role="alert">
        上記の店舗を管理する store_admin として参加します。よろしければ承認してください。
      </div>

      <div class="d-flex gap-2">
        <%= button_to "承認する",
              accept_store_admin_invitation_path(params[:token]),
              method: :post,
              class: "btn btn-primary",
              data: { turbo_confirm: "この店舗（#{@invitation.store.name}）の store_admin 招待を承認しますか？" } %>

        <%= link_to "キャンセル", dashboard_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  <% end %>
</div>
