<div class="container mt-4" style="max-width: 720px;">
  <h1 class="h4 mb-3"><%= @booth.name.presence || "ブース" %></h1>

  <div class="alert alert-secondary" role="alert">
    視聴 / 配信 を選択してください。
  </div>

  <div class="d-flex gap-2">
    <%= link_to "視聴する", booth_path(@booth), class: "btn btn-outline-primary" %>

    <%= button_to "配信する",
          enter_as_cast_booth_path(@booth),
          method: :post,
          class: "btn btn-primary" %>
  </div>

  <div class="mt-3">
    <%= link_to "戻る", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>
</div>
