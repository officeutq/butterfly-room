<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<h1>Public Booth#show (stub)</h1>
<% if notice.present? %>
  <div class="alert alert-success" role="alert"><%= notice %></div>
<% end %>

<% if alert.present? %>
  <div class="alert alert-danger" role="alert"><%= alert %></div>
<% end %>
<p>booth_id: <%= @booth_id %></p>

<% if @stream_session.present? %>
  <div
    data-controller="presence-poll"
    data-presence-poll-ping-url-value="<%= ping_stream_session_presence_path(@stream_session) %>"
    data-presence-poll-summary-url-value="<%= presence_summary_stream_session_path(@stream_session) %>"
    data-presence-poll-interval-ms-value="20000"
  >
    viewers: <span data-presence-poll-target="count">-</span>
  </div>
<% end %>

<% if @stream_session.present? %>
  <%= turbo_stream_from [@stream_session, :pending_drink_orders] %>
<% end %>

<div id="pending-drink-orders-container">
  <% if @stream_session.present? %>
    <%= render "stream_sessions/pending_drink_orders", stream_session: @stream_session %>
  <% else %>
    <div class="text-muted">配信中のみ表示されます</div>
  <% end %>
</div>

<% if @stream_session.present? %>
  <%= turbo_stream_from [@stream_session, :comments] %>

  <div id="comments">
    <%= render partial: "comments/comment", collection: @comments, as: :comment %>
  </div>

  <%= render "stream_sessions/comments/form", stream_session: @stream_session %>
<% else %>
  <p>配信中のみコメントできます</p>
<% end %>

<hr>

<h2>所持ポイント</h2>

<% if user_signed_in? %>
  <p>残高: <strong><%= @wallet&.available_points || 0 %>pt</strong></p>

  <div class="d-flex gap-2 mb-3">
    <%= button_to "1000pt 購入",
          wallet_purchases_path,
          method: :post,
          params: { points: 1000, booth_id: @booth.id },
          form: { data: { turbo: false } },
          class: "btn btn-sm btn-outline-primary" %>

    <%= button_to "3000pt 購入",
          wallet_purchases_path,
          method: :post,
          params: { points: 3000, booth_id: @booth.id },
          form: { data: { turbo: false } },
          class: "btn btn-sm btn-outline-primary" %>
  </div>
<% else %>
  <p class="text-muted">ログインすると購入できます</p>
<% end %>

<hr>

<h2>ドリンクメニュー（enabledのみ）</h2>

<% if @stream_session.blank? %>
  <p>配信中のみドリンク送信できます</p>

<% elsif @drink_items.any? %>
  <ul>
    <% @drink_items.each do |item| %>
      <li class="mb-2">
        <%= item.name %>（<%= item.price_points %>pt）

        <%= button_to "送信",
              stream_session_drink_orders_path(@stream_session),
              method: :post,
              params: { drink_item_id: item.id },
              form: { data: { turbo: false } },
              class: "btn btn-sm btn-primary ms-2" %>
      </li>
    <% end %>
  </ul>

<% else %>
  <p>現在、表示できるドリンクがありません</p>
<% end %>

<hr>

<div class="d-flex justify-content mb-3">
  <%= link_to "退室", root_path, class: "btn btn-outline-secondary" %>
</div>

<hr>

<% if @stream_session.present? %>
  <%= render "stream_sessions/ivs_viewer", stream_session: @stream_session %>
<% end %>

</ul>
