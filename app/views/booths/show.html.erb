<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<h1>Public Booth#show (stub)</h1>

<p>booth_id: <%= @booth.id %></p>

<%# ★booth単位で常時購読（開始/終了/状態変化を自動反映） %>
<%= turbo_stream_from [@booth, :stream_state] %>

<%# ★箱（wrapper）は show 側に固定。idを絶対に消さない %>
<div id="stream_state">
  <%= render "booths/stream_state",
        booth: @booth,
        stream_session: @stream_session,
        comments: @comments,
        drink_items: @drink_items %>
</div>

<hr>

<h2>所持ポイント</h2>

<% if user_signed_in? %>
  <p>残高: <strong><%= @wallet&.available_points || 0 %>pt</strong></p>

  <div class="d-flex gap-2 mb-3">
    <%= button_to "1000pt 購入",
          wallet_purchases_path,
          method: :post,
          params: { points: 1000, booth_id: @booth.id },
          form: { data: { turbo: false } },
          class: "btn btn-sm btn-outline-primary" %>

    <%= button_to "3000pt 購入",
          wallet_purchases_path,
          method: :post,
          params: { points: 3000, booth_id: @booth.id },
          form: { data: { turbo: false } },
          class: "btn btn-sm btn-outline-primary" %>
  </div>
<% else %>
  <p class="text-muted">ログインすると購入できます</p>
<% end %>

<hr>

<div class="d-flex justify-content mb-3">
  <%= link_to "退室", root_path, class: "btn btn-outline-secondary" %>
</div>
