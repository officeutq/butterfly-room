<%# locals: f:, booth:, submit_label:, back_path: %>
<% cast_memberships = local_assigns.fetch(:cast_memberships, []) %>
<% show_cast_assignment = local_assigns.fetch(:show_cast_assignment, false) %>
<% primary_cast_user = booth.primary_cast_user %>

<% if booth.errors.any? %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% booth.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mb-3">
  <%= f.label :name, "ブース名", class: "form-label" %>
  <%= f.text_field :name, class: "form-control", required: true %>
</div>

<div class="mb-3">
  <%= f.label :description, "説明文", class: "form-label" %>
  <%= f.text_area :description, class: "form-control", rows: 6 %>
</div>

<% if show_cast_assignment || primary_cast_user.present? %>
  <div class="mb-3">
    <label class="form-label">所属キャスト</label>

    <% if primary_cast_user.present? %>
      <div class="form-control-plaintext">
        <%= user_avatar_badge(primary_cast_user, size: 28) %>
        <%= display_name_or_anonymous(primary_cast_user) %>
        <span class="form-text small">
          ( 変更不可 )
        </span>
      </div>
    <% else %>
      <%= select_tag "booth_cast[cast_user_id]",
            options_for_select(cast_memberships.map { |m| [ display_name_or_anonymous(m.user), m.user.id ] }),
            include_blank: "未設定",
            class: "form-select" %>
      <div class="form-text small">
        キャストは後から未設定ブースにのみ紐づけできます。紐づけ後は変更できません。
      </div>
    <% end %>
  </div>
<% end %>

<div
  class="mb-3 image-upload-field"
  data-controller="image-upload"
  data-image-upload-width-value="1920"
  data-image-upload-height-value="1080"
  <% if booth.thumbnail_image.attached? %>
    data-image-upload-initial-url-value="<%= url_for(booth.thumbnail_image) %>"
  <% end %>>
  <%= f.label :thumbnail_image, "サムネ画像", class: "form-label" %>

  <%= f.hidden_field :remove_thumbnail_image,
        value: "0",
        data: { "image-upload-target": "removeFlag" } %>

  <%= f.file_field :thumbnail_image,
        accept: ".jpg,.jpeg,.png,.webp,.heic,.heif",
        data: { "image-upload-target": "input" } %>
</div>

<div class="d-flex gap-2">
  <%= f.submit submit_label, class: "btn btn-primary" %>
  <%= link_to "戻る", back_path, class: "btn btn-outline-secondary" %>
</div>
