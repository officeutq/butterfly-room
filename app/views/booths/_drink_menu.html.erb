<%# locals: booth:, stream_session:, drink_items:, error_message: (optional) %>

<turbo-frame id="drink_menu">
  <% if local_assigns[:error_message].present? %>
    <div class="alert alert-danger py-1 mb-2"><%= error_message %></div>
  <% end %>

  <h2>ドリンクメニュー（enabledのみ）</h2>

  <% live_like = booth.live? || booth.away? %>

  <% if stream_session.present? && live_like %>
    <% if (drink_items || []).any? %>
      <ul class="mb-0">
        <% (drink_items || []).each do |item| %>
          <li class="mb-2">
            <%= item.name %>（<%= item.price_points %>pt）

            <%= form_with url: stream_session_drink_orders_path(stream_session),
                          scope: :drink_order,
                          method: :post,
                          class: "d-inline" do |f| %>
              <%= f.hidden_field :drink_item_id, value: item.id %>
              <%= f.submit "送信", class: "btn btn-sm btn-primary ms-2" %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="mb-0">現在、表示できるドリンクがありません</p>
    <% end %>
  <% else %>
    <p class="mb-0">配信中のみドリンク送信できます</p>
  <% end %>
</turbo-frame>
