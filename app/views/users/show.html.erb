<div class="user-show">
  <div class="user-show-hero">
    <% if @user.avatar.attached? %>
      <%= image_tag @user.avatar,
            class: "user-show-hero-image",
            alt: display_name_or_anonymous(@user) %>
    <% else %>
      <div class="user-show-hero-placeholder">
        <span class="text-muted">no image</span>
      </div>
    <% end %>
  </div>

  <div class="container user-show-container">
    <div class="user-show-header d-flex justify-content-between align-items-start gap-3">
      <div class="min-w-0">
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <h1 class="user-show-title mb-0"><%= display_name_or_anonymous(@user) %></h1>

          <% role_label = user_role_label(@user) %>
          <% if role_label.present? %>
            <span class="badge rounded-pill text-bg-secondary"><%= role_label %></span>
          <% end %>
        </div>
      </div>

      <div class="user-show-favorite"></div>
    </div>

    <div class="user-show-description mt-4">
      <%= simple_format(@user.bio.presence || "自己紹介はまだ書かれていません") %>
    </div>

    <% if @user.cast? %>
      <div class="user-show-related mt-4">
        <h2 class="h5 mb-3"><%= display_name_or_anonymous(@user) %>のブース一覧</h2>

        <% if @cast_booths.blank? %>
          <div class="alert alert-warning mb-0" role="alert">
            公開中のブースがありません。
          </div>
        <% else %>
          <div class="row g-3">
            <% @cast_booths.each do |booth| %>
              <div class="col-12 col-md-6 col-xl-4">
                <%= render "booths/card",
                      booth: booth,
                      booth_favorited: @favorite_booth_ids.include?(booth.id),
                      store_favorited: @favorite_store_ids.include?(booth.store_id) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <% if @user.store_admin? %>
      <div class="user-show-related mt-4">
        <h2 class="h5 mb-3"><%= display_name_or_anonymous(@user) %>の所属店舗</h2>

        <% if @admin_stores.blank? %>
          <div class="alert alert-warning mb-0" role="alert">
            所属店舗がありません。
          </div>
        <% else %>
          <div class="row g-3">
            <% @admin_stores.each do |store| %>
              <div class="col-12 col-md-6 col-xl-4">
                <%= render "stores/card",
                      store: store,
                      favorited: @favorite_store_ids.include?(store.id) %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
