<%# locals: user: %>

<div class="card h-100 shadow-sm users-card" data-bs-theme="light">
  <div class="users-card-thumbnail-wrap">
    <%= link_to user_path(user), class: "d-block users-card-thumbnail-link" do %>
      <% if user.avatar.attached? %>
        <%= image_tag user.avatar, class: "card-img-top users-card-thumbnail" %>
      <% else %>
        <div class="users-card-thumbnail users-card-thumbnail-placeholder">
          <span class="text-muted small">no image</span>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="card-body d-flex flex-column">
    <div class="users-card-row">
      <div class="users-card-label">ユーザー名</div>

      <div class="users-card-value users-card-value-emphasis d-flex align-items-center gap-2">
        <%= link_to display_name_or_anonymous(user),
              user_path(user),
              class: "users-card-name-link text-decoration-none text-reset" %>

        <% if (role_label = user_role_label(user)).present? %>
          <span class="badge text-bg-secondary"><%= role_label %></span>
        <% end %>
      </div>

      <div class="users-card-action">
        <%= render "favorites/users/button_home",
              user: user,
              favorited: @favorite_user_ids.include?(user.id),
              dom_id: "user_#{user.id}_favorite_button_card_#{user.id}" %>
      </div>
    </div>

    <div class="users-card-row users-card-row-summary">
      <div class="users-card-label">自己紹介</div>

      <div class="users-card-value users-card-summary text-truncate">
        <%= user.bio.presence || "-" %>
      </div>
    </div>
  </div>
</div>
