<% content_for :title, "精算（予定・履歴）" %>

<div class="row justify-content-center">
  <div class="col-12 col-lg-9">

    <div class="mb-3">
      <h2 class="h6 mb-1">次回精算予定（概算）</h2>
      <div class="small text-muted">
        未確定の予定額の概算です。
      </div>
    </div>

    <div class="card mb-4" data-bs-theme="light">
      <div class="card-body">
        <div class="alert alert-secondary mb-4" role="alert">
          <div class="fw-semibold mb-1">表示について</div>
          <div class="small fw-semibold">
            ・精算は月次で行われます（翌月10日）。<br>
            ・1万円未満は翌月へ繰越されます。<br>
            ・表示金額は概算です。精算確定（運営側処理）により変動することがあります。
          </div>
        </div>

        <div class="mb-3">
          <div class="small text-muted">
            <div>集計期間</div>
            <div>開始：<%= l(@month_from) %></div>
            <div>終了：<%= l(@month_to) %></div>
          </div>
        </div>

        <div class="rounded-3 border bg-body-tertiary p-3 mb-3">
          <div class="small text-muted mb-1">支払予定額</div>

          <% if @below_min_payout %>
            <div class="h2 mb-1">0 円</div>
            <div class="small text-muted">
              1万円未満のため、次回精算へ繰り越されます。
            </div>
          <% else %>
            <div class="h2 mb-0">
              <%= number_with_delimiter(@estimated_payable_yen) %> 円
            </div>
          <% end %>
        </div>

        <div class="row g-2">
          <div class="col-12 col-md-4">
            <div class="rounded-3 border p-3 h-100">
              <div class="small text-muted mb-1">当月の消化pt合計</div>
              <div class="fw-semibold">
                <%= number_with_delimiter(@month_gross_yen) %> pt
              </div>
            </div>
          </div>

          <div class="col-12 col-md-4">
            <div class="rounded-3 border p-3 h-100">
              <div class="small text-muted mb-1">店舗取り分（70%・概算）</div>
              <div class="fw-semibold">
                <%= number_with_delimiter(@month_share_yen) %> 円
              </div>
            </div>
          </div>

          <div class="col-12 col-md-4">
            <div class="rounded-3 border p-3 h-100">
              <div class="small text-muted mb-1">前月からの繰越</div>
              <div class="fw-semibold">
                <%= number_with_delimiter(@carryover_yen) %> 円
              </div>
            </div>
          </div>
        </div>

        <% if @below_min_payout %>
          <div class="small text-muted mt-3">
            参考：現在の精算対象額は <%= number_with_delimiter(@estimated_payable_yen) %> 円です。
          </div>
        <% end %>
      </div>
    </div>

    <div class="mb-3">
      <h2 class="h6 mb-1">精算履歴</h2>
      <div class="small text-muted">
        確定済みの精算履歴を確認できます。
      </div>
    </div>

    <% if @settlements.any? %>
      <div class="vstack gap-3">
        <% @settlements.each do |s| %>
          <%= link_to admin_settlement_path(s), class: "card text-decoration-none text-body", data: { "bs-theme": "light" } do %>
            <div class="card-body">
              <div class="row g-2 align-items-start mb-3">
                <div class="col-12 col-sm">
                  <div class="small text-muted">
                    <div>集計期間</div>
                    <div>開始：<%= l(s.period_from) %></div>
                    <div>終了：<%= l(s.period_to) %></div>
                  </div>
                </div>
                <div class="col-12 col-sm-auto text-sm-end">
                  <span class="badge text-bg-secondary">
                    <%= settlement_status_label(s) %>
                  </span>
                </div>
              </div>
              <div class="rounded-3 border bg-body-tertiary p-3 mb-3">
                <div class="small text-muted mb-1">支払予定額</div>
                <div class="h4 mb-0">
                  <%= number_with_delimiter(s.store_share_yen) %> 円
                </div>
              </div>
              <div class="small text-muted mt-3">
                詳細を確認
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="card" data-bs-theme="light">
        <div class="card-body">
          <div class="text-muted small">
            精算履歴はまだありません。
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
