<% content_for :title, "振込先口座設定" %>

<div class="row justify-content-center">
  <div class="col-12 col-md-8 col-lg-6">
    <div class="card mb-4" data-bs-theme="light">
      <div class="card-body">
        <h1 class="h4 mb-3">振込先口座設定</h1>

        <p class="small text-muted mb-3">
          ※ 振込先口座は精算処理に利用されます。誤りがあると入金できない場合があります。<br>
          ※ この画面では口座の照会や任意の送金操作はできません（精算は月次で行われます）。
        </p>

        <% if @active_payout_account.present? && @store.payout_account_configured? %>
          <div class="alert alert-success" role="alert">
            <div class="fw-semibold mb-2">現在の設定状況</div>

            <% if @active_payout_account.jp_bank? %>
              <dl class="row mb-0">
                <dt class="col-sm-4">口座種別</dt>
                <dd class="col-sm-8">ゆうちょ銀行</dd>

                <dt class="col-sm-4">記号</dt>
                <dd class="col-sm-8"><%= @active_payout_account.jp_bank_symbol.presence || "-" %></dd>

                <dt class="col-sm-4">番号</dt>
                <dd class="col-sm-8">
                  <% jp_last4 = @active_payout_account.jp_bank_number.to_s.last(4) %>
                  <%= jp_last4.present? ? "****#{jp_last4}" : "-" %>
                </dd>

                <dt class="col-sm-4">口座名義カナ</dt>
                <dd class="col-sm-8 mb-0"><%= truncate(@active_payout_account.account_holder_kana.to_s, length: 32) %></dd>
              </dl>
            <% else %>
              <dl class="row mb-0">
                <dt class="col-sm-4">口座種別</dt>
                <dd class="col-sm-8">銀行口座</dd>

                <dt class="col-sm-4">銀行コード</dt>
                <dd class="col-sm-8"><%= @active_payout_account.bank_code %></dd>

                <dt class="col-sm-4">支店コード</dt>
                <dd class="col-sm-8"><%= @active_payout_account.branch_code %></dd>

                <dt class="col-sm-4">預金種目</dt>
                <dd class="col-sm-8">
                  <%= @active_payout_account.ordinary? ? "普通" : "当座" %>
                </dd>

                <dt class="col-sm-4">口座番号</dt>
                <dd class="col-sm-8">
                  <% last4 = @store.payout_account_last4 %>
                  <%= last4.present? ? "****#{last4}" : "-" %>
                </dd>

                <dt class="col-sm-4">口座名義カナ</dt>
                <dd class="col-sm-8 mb-0"><%= truncate(@active_payout_account.account_holder_kana.to_s, length: 32) %></dd>
              </dl>
            <% end %>
          </div>

          <p class="text-muted">
            新しい口座情報を入力して登録すると、登録済み口座情報を上書きできます。
          </p>
        <% else %>
          <div class="alert alert-secondary" role="alert">
            振込先口座はまだ設定されていません。
          </div>
        <% end %>

        <hr class="my-4">

        <h2 class="h6 mb-3">口座情報</h2>

        <%= form_with model: @payout_account,
              url: admin_payout_account_path,
              method: :patch do |f| %>

          <% selected_kind = @payout_account.input_account_kind.presence || "bank" %>

          <% if @payout_account.errors.any? %>
            <div class="alert alert-danger" role="alert">
              <ul class="mb-0">
                <% @payout_account.errors.full_messages.each do |msg| %>
                  <li><%= msg %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="mb-4">
            <label class="form-label">口座の種類</label>

            <div class="row g-2">
              <div class="col-12 col-sm-6">
                <label class="card h-100 p-3" for="account_kind_bank">
                  <div class="form-check mb-0">
                    <%= f.radio_button :input_account_kind,
                          "bank",
                          checked: selected_kind != "jp_bank",
                          class: "form-check-input",
                          id: "account_kind_bank" %>
                    <span class="form-check-label fw-semibold">銀行口座</span>
                  </div>
                  <div class="small text-muted mt-2">
                    銀行コード・支店コード・口座番号で登録します。
                  </div>
                </label>
              </div>

              <div class="col-12 col-sm-6">
                <label class="card h-100 p-3" for="account_kind_jp_bank">
                  <div class="form-check mb-0">
                    <%= f.radio_button :input_account_kind,
                          "jp_bank",
                          checked: selected_kind == "jp_bank",
                          class: "form-check-input",
                          id: "account_kind_jp_bank" %>
                    <span class="form-check-label fw-semibold">ゆうちょ銀行</span>
                  </div>
                  <div class="small text-muted mt-2">
                    記号・番号から振込用口座情報へ自動変換します。
                  </div>
                </label>
              </div>
            </div>
          </div>

          <div id="bank_payout_account_fields">
            <div class="mb-3">
              <%= f.label :bank_code, "銀行コード（4桁）", class: "form-label" %>
              <%= f.text_field :bank_code, class: "form-control", inputmode: "numeric", autocomplete: "off" %>
            </div>

            <div class="mb-3">
              <%= f.label :branch_code, "支店コード（3桁）", class: "form-label" %>
              <%= f.text_field :branch_code, class: "form-control", inputmode: "numeric", autocomplete: "off" %>
            </div>

            <div class="mb-3">
              <%= f.label :account_type, "預金種目", class: "form-label" %>
              <%= f.select :account_type,
                    options_for_select([["普通", "ordinary"], ["当座", "current"]], @payout_account.account_type),
                    { include_blank: true },
                    class: "form-select" %>
            </div>

            <div class="mb-3">
              <%= f.label :account_number, "口座番号（7桁）", class: "form-label" %>
              <%= f.text_field :account_number, class: "form-control", inputmode: "numeric", autocomplete: "off" %>
            </div>
          </div>

          <div id="jp_bank_payout_account_fields">
            <div class="mb-3">
              <%= f.label :jp_bank_symbol, "記号（5桁）", class: "form-label" %>
              <%= f.text_field :jp_bank_symbol,
                    class: "form-control",
                    inputmode: "numeric",
                    autocomplete: "off",
                    aria: { describedby: "jp_bank_symbol_help" } %>
              <div id="jp_bank_symbol_help" class="form-text small">
                ・記号は「1」から始まる5桁で入力してください。<br>・記号が「1」以外で始まる場合は、振込用の店番・口座番号を確認し、「銀行口座」として入力してください。
              </div>
            </div>
            <div class="mb-3">
              <%= f.label :jp_bank_number, "番号（2〜8桁）", class: "form-label" %>
              <%= f.text_field :jp_bank_number, class: "form-control", inputmode: "numeric", autocomplete: "off" %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :account_holder_kana, "口座名義カナ", class: "form-label" %>
            <%= f.text_field :account_holder_kana, class: "form-control", autocomplete: "off" %>
          </div>

          <div class="d-flex gap-2">
            <%= f.submit "更新する", class: "btn btn-primary" %>
            <%= link_to "戻る", dashboard_path, class: "btn btn-outline-secondary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<script>
  (() => {
    const togglePayoutAccountFields = () => {
      const jpBankRadio = document.getElementById("account_kind_jp_bank")
      const bankFields = document.getElementById("bank_payout_account_fields")
      const jpBankFields = document.getElementById("jp_bank_payout_account_fields")

      if (!jpBankRadio || !bankFields || !jpBankFields) return

      const isJpBank = jpBankRadio.checked

      bankFields.classList.toggle("d-none", isJpBank)
      jpBankFields.classList.toggle("d-none", !isJpBank)
    }

    document.addEventListener("turbo:load", () => {
      document.getElementById("account_kind_bank")?.addEventListener("change", togglePayoutAccountFields)
      document.getElementById("account_kind_jp_bank")?.addEventListener("change", togglePayoutAccountFields)

      togglePayoutAccountFields()
    })

    document.addEventListener("turbo:render", togglePayoutAccountFields)
  })()
</script>
