<h1>ブース管理</h1>

<div class="mb-3 d-flex gap-2 align-items-center">
  <%= link_to "新規作成", new_admin_booth_path, class: "btn btn-primary" %>

  <% if params[:archived].present? %>
    <%= link_to "現役のみ表示", admin_booths_path, class: "btn btn-outline-secondary" %>
  <% else %>
    <%= link_to "アーカイブも表示", admin_booths_path(archived: 1), class: "btn btn-outline-secondary" %>
  <% end %>
</div>

<table class="table table-sm align-middle">
  <thead>
    <tr>
      <th>ID</th>
      <th>名前</th>
      <th>Status</th>
      <th>IVS Stage ARN</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @booths.each do |booth| %>
      <tr class="<%= "text-muted" if booth.archived? %>">
        <td><%= booth.id %></td>

        <td>
          <%= button_to booth.name,
                enter_booth_path(booth),
                method: :get,
                class: "btn btn-outline-primary btn-sm",
                form: {
                  class: "d-inline",
                  data: {
                    turbo_frame: "modal",
                    turbo_confirm: enter_booth_switch_confirm_message(booth)
                  }
                } %>
        </td>

        <td><%= booth.status %></td>

        <td class="text-muted small"><%= booth.ivs_stage_arn.presence || "-" %></td>

        <td>
          <div class="d-flex justify-content-end gap-2 align-items-center">
            <% if booth.archived? %>
              <span class="badge text-bg-secondary">archived</span>
            <% elsif booth.offline? && booth.current_stream_session_id.blank? %>
              <%= button_to "アーカイブ",
                    archive_admin_booth_path(booth),
                    method: :patch,
                    class: "btn btn-outline-danger btn-sm",
                    data: { turbo_confirm: "このブースをアーカイブします。よろしいですか？" } %>
            <% else %>
              <span class="text-muted small">配信終了後にアーカイブ可</span>
            <% end %>
          </div>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
