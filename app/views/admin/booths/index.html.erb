<h1 class="mb-4">ブース一覧</h1>

<div class="mb-4 d-flex gap-2 align-items-center flex-wrap">
  <%= link_to "新規作成", new_admin_booth_path, class: "btn btn-primary" %>

  <% if @include_archived %>
    <%= link_to "現役のみ表示", admin_booths_path, class: "btn btn-outline-secondary" %>
  <% else %>
    <%= link_to "閉鎖済みも表示", admin_booths_path(archived: 1), class: "btn btn-outline-secondary" %>
  <% end %>
</div>

<% if @booths.blank? %>
  <div class="alert alert-warning" role="alert">
    表示できるブースがありません。
  </div>
<% else %>
  <div class="row g-4">
    <% @booths.each do |booth| %>
      <% current_selected = booth.id.to_s == @current_booth_id.to_s %>
      <% archived = booth.archived? %>
      <% booth_cast = booth.booth_casts.first %>
      <% policy = Authorization::BoothPolicy.new(current_user, booth) %>
      <% can_force_end = policy.admin_operate? && booth.current_stream_session_id.present? && (booth.live? || booth.away?) && !archived %>
      <% switch_return_to = @include_archived ? admin_booths_path(archived: 1) : admin_booths_path %>

      <div class="col-12 col-lg-6 col-xxl-4">
        <div class="card h-100 admin-booths-card <%= "is-archived" if archived %>" data-bs-theme="light">
          <div class="ratio ratio-16x9 border-bottom admin-booths-card-thumbnail-wrap">
            <% if booth.thumbnail_image.attached? %>
              <%= image_tag booth.thumbnail_image,
                    class: "w-100 h-100 admin-booths-card-thumbnail",
                    style: "object-fit: cover;",
                    alt: booth.name.presence || "(no name)" %>
            <% else %>
              <div class="d-flex align-items-center justify-content-center bg-body-tertiary admin-booths-card-thumbnail">
                <div class="text-center text-muted">
                  <div class="fs-1 lh-1">
                    <i class="bi bi-camera-video"></i>
                  </div>
                  <div class="small mt-2">サムネイル未設定</div>
                </div>
              </div>
            <% end %>

            <div class="admin-booths-card-overlay">
              <div class="admin-booths-card-overlay-left">
                <% if !archived && !current_selected %>
                  <%= button_to "このブースへ切り替え",
                        cast_current_booth_path,
                        method: :post,
                        params: {
                          booth_id: booth.id,
                          return_to: switch_return_to
                        },
                        class: "btn btn-warning btn-sm",
                        form: {
                          class: "d-inline admin-booths-card-switch-form"
                        } %>
                <% end %>
              </div>

              <div class="admin-booths-card-overlay-right">
                <% if current_selected %>
                  <span class="badge text-bg-success admin-booths-card-badge">選択中</span>
                <% end %>
              </div>
            </div>
          </div>

          <div class="card-body d-flex flex-column">
            <div class="admin-booths-card-title-row">
              <div class="admin-booths-card-title">
                <h2 class="h5 mb-0 admin-booths-card-title-text"><%= booth.name.presence || "(no name)" %></h2>
              </div>

              <div class="admin-booths-card-status d-flex align-items-center gap-2 flex-wrap justify-content-end">
                <%= booth_status_badge(booth) %>

                <% if archived %>
                  <span class="badge text-bg-dark">閉鎖済み</span>
                <% end %>
              </div>
            </div>

            <div class="mt-3">
              <div class="small text-muted mb-1">現在のキャスト</div>

              <% if booth_cast.present? %>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                  <span><%= display_name_or_anonymous(booth_cast.cast_user) %></span>
                </div>
              <% else %>
                <div class="text-muted">未設定</div>
              <% end %>
            </div>

            <% if !archived && booth_cast.blank? %>
              <div class="mt-3">
                <%= form_with url: assign_cast_admin_booth_path(booth), method: :post do %>
                  <%= hidden_field_tag :return_to, switch_return_to %>

                  <div class="d-flex gap-2 align-items-center flex-wrap">
                    <%= select_tag "booth_cast[cast_user_id]",
                          options_for_select(@cast_memberships.map { |m| [ display_name_or_anonymous(m.user), m.user.id ] }),
                          include_blank: "キャストを選択",
                          class: "form-select form-select-sm admin-booths-cast-select",
                          required: true %>

                    <%= submit_tag "紐づけ",
                          class: "btn btn-primary btn-sm",
                          data: { turbo_confirm: "このブースにキャストを紐づけます。紐づけ後は変更できません。よろしいですか？" } %>
                  </div>
                <% end %>
              </div>
            <% end %>

            <div class="mt-auto pt-3">
              <% if archived %>
                <div class="text-muted small">閉鎖済みのため操作できません</div>
              <% else %>
                <div class="admin-booths-card-actions">
                  <%= button_to "配信/視聴",
                        enter_booth_path(booth),
                        method: :get,
                        class: "btn btn-primary btn-sm",
                        form: {
                          class: "d-inline",
                          data: {
                            turbo_frame: "modal",
                            turbo_confirm: enter_booth_switch_confirm_message(booth)
                          }
                        } %>

                  <%= link_to "このブースを選択して編集",
                        edit_cast_booth_path(booth),
                        class: "btn btn-outline-secondary btn-sm" %>

                  <% if can_force_end %>
                    <%= button_to "強制終了",
                          force_end_admin_booth_path(booth),
                          method: :post,
                          class: "btn btn-outline-danger btn-sm",
                          data: { turbo_confirm: "このブースの配信を強制終了します。よろしいですか？" } %>
                  <% end %>

                  <% if (booth.offline? && booth.current_stream_session_id.blank?) || booth.standby? %>
                    <%= button_to "閉鎖",
                          archive_admin_booth_path(booth),
                          method: :patch,
                          class: "btn btn-outline-danger btn-sm",
                          data: { turbo_confirm: "このブースを閉鎖します。よろしいですか？" } %>
                  <% elsif booth.live? || booth.away? %>
                    <span class="text-muted small">配信終了後に閉鎖可</span>
                  <% else %>
                    <span class="text-muted small">状態確認後に閉鎖可</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
