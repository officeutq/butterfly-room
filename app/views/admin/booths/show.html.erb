<h1>ブース詳細</h1>

<p>ivs_stage_arn:</p>
<pre class="bg-light p-2"><%= @booth.ivs_stage_arn.presence || "-" %></pre>

<p>booth: <strong>#<%= @booth.id %> <%= @booth.name %></strong></p>

<p>description:</p>
<pre class="bg-light p-2"><%= @booth.description.presence || "-" %></pre>

<p>thumbnail:</p>
<% if @booth.thumbnail_image.attached? %>
  <%= image_tag @booth.thumbnail_image, style: "max-width: 240px; height: auto;" %>
<% else %>
  <div class="text-muted">なし</div>
<% end %>

<%# 視聴導線（配信中のみ watch に行く） %>
<div class="mt-3 d-flex gap-2">
  <%= link_to "視聴", watch_admin_booth_path(@booth), class: "btn btn-primary btn-sm" %>

  <%# 既存の編集導線（権限ありのみ） %>
  <% policy = Authorization::BoothPolicy.new(current_user, @booth) %>
  <% if policy.update? %>
    <%= link_to "編集", edit_admin_booth_path(@booth), class: "btn btn-outline-secondary btn-sm" %>
  <% end %>
</div>
