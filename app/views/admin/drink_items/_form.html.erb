<%= form_with model: drink_item, url: url, method: method do |f| %>
  <% if drink_item.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% drink_item.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-5">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :price_points, class: "form-label" %>
      <%= f.number_field :price_points, min: 1, class: "form-control" %>
    </div>

    <div class="col-md-2">
      <%= f.label :position, class: "form-label" %>
      <%= f.number_field :position, class: "form-control" %>
    </div>

    <div class="col-md-2 d-flex align-items-end">
      <div class="form-check">
        <%= f.check_box :enabled, class: "form-check-input" %>
        <%= f.label :enabled, class: "form-check-label" %>
      </div>
    </div>

    <div class="col-12">
      <%= f.label :icon_key, "アイコン", class: "form-label" %>

      <div class="drink-icon-toggle-list" role="radiogroup" aria-label="ドリンクアイコン選択">
        <%= f.radio_button :icon_key,
                           "",
                           class: "btn-check",
                           id: "drink_icon_none_#{drink_item.id || 'new'}",
                           aria: { label: "未設定" } %>
        <label class="btn drink-icon-toggle-btn" for="drink_icon_none_<%= drink_item.id || 'new' %>" title="未設定">
          <%= image_tag "drink_icons/drink_unset.jpg", alt: "", class: "drink-icon-toggle-image" %>
        </label>

        <% DrinkItem::ICON_OPTIONS.each do |key, option| %>
          <%= f.radio_button :icon_key,
                             key,
                             class: "btn-check",
                             id: "drink_icon_#{key}_#{drink_item.id || 'new'}",
                             aria: { label: option[:label] } %>
          <label class="btn drink-icon-toggle-btn"
                 for="drink_icon_<%= key %>_<%= drink_item.id || 'new' %>"
                 title="<%= option[:label] %>">
            <%= image_tag option[:path], alt: "", class: "drink-icon-toggle-image" %>
          </label>
        <% end %>
      </div>
    </div>

    <div class="col-12">
      <%= f.submit "保存", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>
