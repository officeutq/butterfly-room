<% content_for :title, "通報一覧" %>

<div class="mb-4 d-flex gap-2 align-items-center flex-wrap">
  <% if @include_resolved %>
    <%= link_to "対応待ちのみ表示", admin_comment_reports_path, class: "btn btn-outline-secondary" %>
  <% else %>
    <%= link_to "全件表示", admin_comment_reports_path(with_resolved: 1), class: "btn btn-outline-secondary" %>
  <% end %>
</div>

<% if @report_cards.blank? %>
  <div class="alert alert-warning" role="alert">
    現在、この店舗の通報はありません。
  </div>
<% else %>
  <div class="row g-4">
    <% @report_cards.each do |card| %>
      <div class="col-12 col-lg-6 col-xxl-4">
        <%= render "card", card: card %>
      </div>
    <% end %>
  </div>
<% end %>
