<% content_for :title, "キャスト一覧" %>

<div class="mb-4 d-flex gap-2 align-items-center flex-wrap">
  <%= link_to "キャスト招待", admin_cast_invitations_path, class: "btn btn-primary" %>
</div>

<% if @cast_memberships.blank? %>
  <div class="alert alert-warning" role="alert">
    所属中のキャストがいません。
  </div>
<% else %>
  <div class="row g-4">
    <% @cast_memberships.each do |membership| %>
      <% user = membership.user %>
      <% booths =
           user.booth_casts
               .filter_map { |booth_cast| booth_cast.booth if booth_cast.booth&.store_id == current_store.id }
               .uniq(&:id)
               .sort_by(&:id) %>

      <div class="col-12 col-lg-6 col-xxl-4">
        <div class="card h-100" data-bs-theme="light">
          <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-start gap-3">
              <div class="flex-shrink-0">
                <%= user_avatar_badge(user, size: 64) %>
              </div>

              <div class="flex-grow-1 min-w-0">
                <h2 class="h5 mb-1"><%= display_name_or_anonymous(user) %></h2>
                <div class="small text-muted text-break">
                  <%= truncate(user.bio.to_s.squish.presence || "紹介文未設定", length: 60) %>
                </div>
              </div>
            </div>

            <div class="mt-3">
              <div class="small text-muted mb-2">所属ブース</div>

              <% if booths.present? %>
                <div class="d-flex gap-2 flex-wrap">
                  <% booths.each do |booth| %>
                    <span class="badge text-bg-secondary"><%= booth.name.presence || "(no name)" %></span>
                  <% end %>
                </div>
              <% else %>
                <div class="text-muted">未設定</div>
              <% end %>
            </div>

            <div class="mt-auto pt-3">
              <%= button_to "削除",
                    admin_cast_path(membership),
                    method: :delete,
                    data: { turbo_confirm: "このキャスト登録を解除しますか？" },
                    class: "btn btn-sm btn-outline-danger" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
