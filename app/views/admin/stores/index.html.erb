<% content_for :title, "店舗を選択" %>

<% if @stores.blank? %>
  <div class="alert alert-warning" role="alert">
    管理可能な店舗がありません。
  </div>
<% else %>
  <table class="table align-middle">
    <thead>
      <tr>
        <th>ID</th>
        <th>店舗名</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @stores.each do |store| %>
        <tr class="<%= "table-active" if store.id.to_s == @current_store_id.to_s %>">
          <td><%= store.id %></td>
          <td><%= store.name.presence || "(no name)" %></td>
          <td class="text-end">
            <%= button_to "この店舗に切替",
                  admin_current_store_path,
                  method: :post,
                  params: {
                    store_id: store.id,
                    return_to: @return_to,
                    return_to_key: @return_to_key
                  },
                  class: "btn btn-primary btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>
