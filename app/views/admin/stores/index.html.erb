<h1>店舗を選択</h1>

<% if @stores.blank? %>
  <div class="alert alert-warning" role="alert">
    管理可能な店舗がありません。
  </div>
<% else %>
  <table class="table align-middle">
    <thead>
      <tr>
        <th>ID</th>
        <th>店舗名</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @stores.each do |store| %>
        <tr class="<%= "table-active" if store.id.to_s == @current_store_id.to_s %>">
          <td><%= store.id %></td>
          <td><%= store.name.presence || "(no name)" %></td>
          <td class="text-end">
            <%= button_to "この店舗を開く",
                  admin_current_store_path(store_id: store.id),
                  method: :post,
                  class: "btn btn-primary btn-sm" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<p class="mt-3">
  <%= link_to "管理者トップへ", admin_root_path, class: "btn btn-outline-secondary" %>
</p>
