<%# locals: f:, store:, submit_label:, back_path: %>

<div class="mb-3">
  <%= f.label :name, "店舗名（必須）", class: "form-label" %>
  <%= f.text_field :name, class: "form-control", required: true %>
</div>

<div class="mb-3">
  <%= f.label :description, "概要", class: "form-label" %>
  <%= f.text_area :description, class: "form-control", rows: 6 %>
  <div class="form-text">最大1000文字</div>
</div>

<div class="mb-3">
  <%= f.label :area, "地域", class: "form-label" %>
  <%= f.text_field :area, class: "form-control" %>
  <div class="form-text">最大50文字（例：渋谷 / 福岡市中央区 など）</div>
</div>

<div class="mb-3">
  <%= f.label :business_type, "業態", class: "form-label" %>
  <%= f.select :business_type,
        options_for_select(Store.business_type_select_options, store.business_type),
        { include_blank: true },
        class: "form-select" %>
</div>

<div class="mb-3">
  <%= f.label :address, "住所", class: "form-label" %>
  <%= f.text_field :address, class: "form-control" %>
  <div class="form-text">保存時に住所から座標を自動取得します</div>
</div>

<div class="mb-3">
  <%= f.label :phone_number, "電話番号", class: "form-label" %>
  <%= f.text_field :phone_number, class: "form-control" %>
</div>

<div class="mb-3">
  <%= f.label :business_hours, "営業時間", class: "form-label" %>
  <%= f.text_field :business_hours, class: "form-control" %>
  <div class="form-text">例：20:00〜LAST / 平日 19:00〜1:00 など</div>
</div>

<div class="mb-3">
  <%= f.label :website_url, "ホームページURL", class: "form-label" %>
  <%= f.text_field :website_url, class: "form-control", placeholder: "https://example.com" %>
</div>

<div class="mb-3">
  <%= f.label :x_url, "X URL", class: "form-label" %>
  <%= f.text_field :x_url, class: "form-control", placeholder: "https://x.com/..." %>
</div>

<div class="mb-3">
  <%= f.label :instagram_url, "Instagram URL", class: "form-label" %>
  <%= f.text_field :instagram_url, class: "form-control", placeholder: "https://www.instagram.com/..." %>
</div>

<div class="mb-3">
  <%= f.label :tiktok_url, "TikTok URL", class: "form-label" %>
  <%= f.text_field :tiktok_url, class: "form-control", placeholder: "https://www.tiktok.com/..." %>
</div>

<div class="mb-3">
  <%= f.label :youtube_url, "YouTube URL", class: "form-label" %>
  <%= f.text_field :youtube_url, class: "form-control", placeholder: "https://www.youtube.com/..." %>
</div>

<div
  class="mb-3 image-upload-field"
  data-controller="image-upload"
  data-image-upload-width-value="1920"
  data-image-upload-height-value="1080"
  <% if store.thumbnail.attached? %>
    data-image-upload-initial-url-value="<%= url_for(store.thumbnail) %>"
  <% end %>>
  <%= f.label :thumbnail, "サムネイル画像", class: "form-label" %>

  <%= f.hidden_field :remove_thumbnail,
        value: "0",
        data: { "image-upload-target": "removeFlag" } %>

  <%= f.file_field :thumbnail,
        accept: ".jpg,.jpeg,.png,.webp,.heic,.heif",
        data: { "image-upload-target": "input" } %>
</div>

<div class="d-flex gap-2">
  <%= f.submit submit_label, class: "btn btn-primary" %>
  <%= link_to "戻る", back_path, class: "btn btn-outline-secondary" %>
</div>
