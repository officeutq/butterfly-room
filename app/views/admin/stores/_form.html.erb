<%# locals: f:, store:, submit_label:, back_path: %>

<% if store.errors.any? %>
  <div class="alert alert-danger" role="alert">
    <ul class="mb-0">
      <% store.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<div class="mb-3">
  <%= f.label :name, "店舗名（必須）", class: "form-label" %>
  <%= f.text_field :name, class: "form-control", required: true %>
</div>

<div class="mb-3">
  <%= f.label :description, "概要", class: "form-label" %>
  <%= f.text_area :description, class: "form-control", rows: 6 %>
  <div class="form-text">最大1000文字</div>
</div>

<div class="mb-3">
  <%= f.label :area, "地域", class: "form-label" %>
  <%= f.text_field :area, class: "form-control" %>
  <div class="form-text">最大50文字（例：渋谷 / 福岡市中央区 など）</div>
</div>

<div class="mb-3">
  <%= f.label :business_type, "業態", class: "form-label" %>
  <%= f.select :business_type,
        options_for_select(Store.business_type_select_options, store.business_type),
        { include_blank: true },
        class: "form-select" %>
</div>

<div
  class="mb-3 image-upload-field"
  data-controller="image-upload"
  data-image-upload-width-value="1920"
  data-image-upload-height-value="1080"
  <% if store.thumbnail.attached? %>
    data-image-upload-initial-url-value="<%= url_for(store.thumbnail) %>"
  <% end %>>
  <%= f.label :thumbnail, "サムネイル画像", class: "form-label" %>

  <%= f.hidden_field :remove_thumbnail,
        value: "0",
        data: { "image-upload-target": "removeFlag" } %>

  <%= f.file_field :thumbnail,
        accept: ".jpg,.jpeg,.png,.webp,.heic,.heif",
        data: { "image-upload-target": "input" } %>
</div>

<div class="d-flex gap-2">
  <%= f.submit submit_label, class: "btn btn-primary" %>
  <%= link_to "戻る", back_path, class: "btn btn-outline-secondary" %>
</div>
