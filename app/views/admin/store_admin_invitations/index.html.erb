<h1 class="mb-4">店舗管理者招待</h1>

<div class="mb-4 d-flex gap-2 align-items-center flex-wrap">
  <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "btn btn-outline-secondary" %>
</div>

<div class="card mb-4" data-bs-theme="light">
  <div class="card-body">
    <p class="text-muted mb-3">
      招待URLを発行し、store_admin ロールのユーザーが承認した場合のみ、
      店舗管理者所属（store_memberships: admin）が作成されます（ロール付け替えは行いません）。
    </p>

    <%= button_to "招待URLを発行",
          admin_store_admin_invitations_path,
          method: :post,
          class: "btn btn-primary" %>

    <div class="mt-3 text-muted small">
      ※発行後のURLは「お知らせ（notice）」にも表示されます。必要に応じてコピペしてください。
    </div>
  </div>
</div>

<h2 class="h5 mt-4">招待一覧</h2>

<% if @store_admin_invitations.blank? %>
  <div class="alert alert-warning" role="alert">
    発行済みの店舗管理者招待はありません。
  </div>
<% else %>
  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead>
        <tr>
          <th>状態</th>
          <th>期限</th>
          <th>発行者</th>
          <th>承認者</th>
          <th>URL</th>
        </tr>
      </thead>

      <tbody>
        <% @store_admin_invitations.each do |inv| %>
          <tr>
            <td><%= inv.status_label %></td>
            <td><%= inv.expires_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td><%= display_name_or_anonymous(inv.invited_by_user) %></td>
            <td>
              <% if inv.accepted_by_user.present? %>
                <%= display_name_or_anonymous(inv.accepted_by_user) %>
              <% else %>
                -
              <% end %>
            </td>
            <td class="text-nowrap">
              <% if inv.issued_url.present? %>
                <div class="d-flex align-items-center gap-2">
                  <span class="small text-break" style="max-width: 360px;">
                    <%= inv.issued_url %>
                  </span>

                  <button
                    type="button"
                    class="btn btn-sm btn-outline-secondary"
                    data-controller="clipboard"
                    data-clipboard-text="<%= inv.issued_url %>"
                    data-action="click->clipboard#copy">
                    コピー
                  </button>
                </div>
              <% else %>
                <span class="text-muted small">（発行時に控えてください）</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
