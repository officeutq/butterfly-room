<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% unless Rails.env.test? %>
      <%= stylesheet_link_tag "bootstrap-icons/font/bootstrap-icons", "data-turbo-track": "reload" %>
    <% end %>
    <%= javascript_importmap_tags %>
    <script
      src="https://web-broadcast.live-video.net/1.30.0/amazon-ivs-web-broadcast.js"
      data-turbo-track="reload"
    ></script>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%# --- Header (common) --- %>
    <header class="border-bottom bg-white">
      <div class="container py-2">
        <div class="d-flex justify-content-between align-items-center gap-3">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <div class="fw-semibold">
              <%= content_for(:title).presence || "App" %>
            </div>

            <% if user_signed_in? %>
              <span class="text-muted small">
                <%= display_name_or_email(current_user) %>
              </span>
              <%= role_badge(current_user) %>

              <% store = layout_current_store %>
              <span class="text-muted small">
                store:
                <% if store.present? %>
                  <strong><%= store.name.presence || "(no name)" %></strong>
                <% else %>
                  <span class="text-danger">未選択</span>
                <% end %>
              </span>

              <% booth = layout_current_booth %>
              <span class="text-muted small">
                booth:
                <% if booth.present? %>
                  <strong><%= booth.name.presence || "(no name)" %></strong>
                <% else %>
                  <span class="text-danger">未選択</span>
                <% end %>
              </span>

              <span class="text-muted small">
                points: <strong><%= layout_wallet_points %>pt</strong>
              </span>
            <% else %>
              <span class="text-muted small">未ログイン</span>
            <% end %>
          </div>

          <div class="d-flex align-items-center gap-2">
            <% if user_signed_in? %>
              <%= button_to "ログアウト",
                    destroy_user_session_path,
                    method: :delete,
                    class: "btn btn-sm btn-outline-secondary" %>
            <% else %>
              <%= link_to "ログイン", new_user_session_path, class: "btn btn-sm btn-primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <%# --- Main --- %>
    <main class="flex-grow-1 pb-5">
      <div class="container mt-3">
        <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
        <div id="flash_inner">
          <% if notice.present? %>
            <div class="alert alert-success" role="alert"><%= notice %></div>
          <% end %>

          <% if alert.present? %>
            <div class="alert alert-danger" role="alert"><%= alert %></div>
          <% end %>
        </div>
      </div>

      <div class="container my-4">
        <%= yield %>
      </div>
    </main>

    <%# --- Footer (common top-level navigation) --- %>
    <footer class="border-top bg-white fixed-bottom">
      <div class="container py-2">
        <div class="d-flex justify-content-between align-items-center">
          <div class="d-flex gap-3">
            <%= link_to "ホーム", root_path, class: "btn btn-sm btn-outline-secondary" %>
            <%= link_to "お気に入り", favorites_booths_path, class: "btn btn-sm btn-outline-secondary" %>
          </div>

          <div>
            <% if user_signed_in? && current_user.at_least?(:cast) %>
              <%= link_to "配信", cast_booths_path, class: "btn btn-sm btn-primary" %>
            <% end %>
          </div>

          <div class="d-flex gap-2">
            <%= button_to "購入(1000pt)",
                  wallet_purchases_path,
                  method: :post,
                  params: { points: 1000 },
                  form: { data: { turbo: false } },
                  class: "btn btn-sm btn-outline-primary" %>

            <%= link_to "ダッシュボード", dashboard_path_for(current_user), class: "btn btn-sm btn-outline-secondary" %>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
