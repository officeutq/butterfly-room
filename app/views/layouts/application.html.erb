<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% unless Rails.env.test? %>
      <%= stylesheet_link_tag "bootstrap-icons/font/bootstrap-icons", "data-turbo-track": "reload" %>
    <% end %>
    <%= javascript_importmap_tags %>
    <script
      src="https://web-broadcast.live-video.net/1.30.0/amazon-ivs-web-broadcast.js"
      data-turbo-track="reload"
    ></script>
  </head>

  <body>
    <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
    <div class="container mt-3">
      <div id="flash_inner">
        <% if notice.present? %>
          <div class="alert alert-success" role="alert"><%= notice %></div>
        <% end %>

        <% if alert.present? %>
          <div class="alert alert-danger" role="alert"><%= alert %></div>
        <% end %>
      </div>
    </div>

    <%# admin: current_store 表示（最低限） %>
    <% if current_user.present? && (current_user.store_admin? || current_user.system_admin?) %>
      <div class="container mb-3">
        <div class="d-flex justify-content-between align-items-center">
          <div class="text-muted small">
            現在の店舗:
            <% if defined?(current_store) && current_store.present? %>
              <strong><%= current_store.name.presence || "(no name)" %></strong>
            <% else %>
              <span class="text-danger">未選択</span>
            <% end %>
          </div>

          <% if current_user.store_admin? %>
            <%= link_to "店舗を切り替える", admin_stores_path, class: "btn btn-sm btn-outline-secondary" %>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>
