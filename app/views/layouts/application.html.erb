<!DOCTYPE html>
<html data-bs-theme="dark">
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="App">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <% unless Rails.env.test? %>
      <%= stylesheet_link_tag "bootstrap-icons/font/bootstrap-icons", "data-turbo-track": "reload" %>
    <% end %>
    <%= javascript_importmap_tags %>
    <script
      src="https://web-broadcast.live-video.net/1.30.0/amazon-ivs-web-broadcast.js"
      data-turbo-track="reload"
    ></script>
  </head>

  <body class="d-flex flex-column min-vh-100">
    <%# --- Header (common) --- %>
    <header id="app_header" class="border-bottom bg-body sticky-top">
      <div class="container py-2">
        <div class="d-flex justify-content-between align-items-center gap-3">
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <%# 1) アプリ名（ロゴ） %>
            <div class="fw-semibold">
              <%= image_tag "logo.png", class: "header-logo", alt: (content_for(:title).presence || "App") %>
            </div>

            <% if user_signed_in? %>
              <%# 2) ポイント（アイコン + pt / Turbo更新維持） %>
              <%= turbo_stream_from [current_user, :wallet] %>
              <%= link_to new_wallet_purchase_path(return_to: request.fullpath),
                    data: { turbo_frame: "modal" },
                    class: "text-muted small text-decoration-none d-inline-flex align-items-center gap-1",
                    id: "wallet_balance" do %>
                <%= render "wallets/balance", wallet: current_user.wallet %>
              <% end %>

              <%# 3) アバター（fallback: 頭文字 / 共通ヘルパ） %>
              <%= user_avatar_badge(current_user, size: 24) %>

              <%# 4) 名前（dropdownトグル） %>
              <div class="dropdown">
                <button
                  class="btn btn-sm btn-link text-muted small p-0 text-decoration-none dropdown-toggle"
                  type="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false">
                  <%= display_name_or_anonymous(current_user) %>
                </button>

                <ul class="dropdown-menu dropdown-menu-end">
                  <%# e-mail（常に表示） %>
                  <li>
                    <span class="dropdown-item-text text-muted small">
                      <%= current_user.email %>
                    </span>
                  </li>

                  <% unless current_user.customer? %>
                    <%# 店舗/ブース（現状ロジックを移植：リンク可否・return_to・未選択表示も維持） %>

                    <% store = layout_current_store %>
                    <li>
                      <span class="dropdown-item-text text-muted small">
                        store:
                        <% if current_user.at_least?(:store_admin) %>
                          <% stores_link_params =
                              if request.get? && request.path != "/admin/stores"
                                { return_to: request.fullpath }
                              else
                                {}
                              end %>

                          <%= link_to admin_stores_path(stores_link_params),
                                class: "link-secondary link-underline-opacity-0 link-underline-opacity-100-hover" do %>
                            <% if store.present? %>
                              <strong><%= store.name.presence || "(no name)" %></strong>
                            <% else %>
                              <span class="text-danger">未選択</span>
                            <% end %>
                          <% end %>
                        <% else %>
                          <%# cast: store は表示のみ（クリック不可） %>
                          <% if store.present? %>
                            <strong><%= store.name.presence || "(no name)" %></strong>
                          <% else %>
                            <span class="text-danger">未選択</span>
                          <% end %>
                        <% end %>
                      </span>
                    </li>

                    <% booth = layout_current_booth %>
                    <li>
                      <span class="dropdown-item-text text-muted small">
                        booth:
                        <% if current_user.cast? %>
                          <%= link_to cast_booths_path,
                                class: "link-secondary link-underline-opacity-0 link-underline-opacity-100-hover" do %>
                            <% if booth.present? %>
                              <strong><%= booth.name.presence || "(no name)" %></strong>
                            <% else %>
                              <span class="text-danger">未選択</span>
                            <% end %>
                          <% end %>
                        <% elsif current_user.at_least?(:store_admin) %>
                          <%= link_to cast_booths_path,
                                class: "link-secondary link-underline-opacity-0 link-underline-opacity-100-hover" do %>
                            <% if booth.present? %>
                              <strong><%= booth.name.presence || "(no name)" %></strong>
                            <% else %>
                              <span class="text-danger">未選択</span>
                            <% end %>
                          <% end %>
                        <% else %>
                          <%# 念のため（到達しない想定）：customer は外で除外済み %>
                          <% if booth.present? %>
                            <strong><%= booth.name.presence || "(no name)" %></strong>
                          <% else %>
                            <span class="text-danger">未選択</span>
                          <% end %>
                        <% end %>
                      </span>
                    </li>
                  <% end %>

                  <li><hr class="dropdown-divider"></li>

                  <%# ログアウト（フッターと同一実装を移植：confirm等も追加しない） %>
                  <li>
                    <%= button_to "ログアウト",
                          destroy_user_session_path,
                          method: :delete,
                          class: "dropdown-item" %>
                  </li>
                </ul>
              </div>

              <%# 5) ロールバッジ %>
              <%= role_badge(current_user) %>
            <% else %>
              <span class="text-muted small">未ログイン</span>
            <% end %>
          </div>

          <div class="d-flex align-items-center gap-2">
            <% unless user_signed_in? %>
              <%= link_to "ログイン", new_user_session_path, class: "btn btn-sm btn-primary" %>
            <% end %>
          </div>
        </div>
      </div>
    </header>

    <% live_layout_moved = (controller_path == "cast/booths" && action_name == "live") %>

    <% unless live_layout_moved %>
      <%# --- Main --- %>
      <main class="flex-grow-1 pb-5">
        <div class="container mt-3">
          <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
          <div id="flash_inner">
            <% if notice.present? %>
              <div class="alert alert-success" role="alert"><%= notice %></div>
            <% end %>

            <% if alert.present? %>
              <div class="alert alert-danger" role="alert"><%= alert %></div>
            <% end %>
          </div>
        </div>

        <div class="container my-4">
          <%= yield %>
        </div>
      </main>

      <%# --- Footer (common top-level navigation) --- %>
      <footer id="app_footer" class="border-top bg-body fixed-bottom">
        <div class="container py-2">
          <div class="d-flex justify-content-between align-items-center">
            <div class="d-flex gap-3">
              <%= link_to "ホーム", root_path, class: "btn btn-sm btn-outline-secondary" %>
              <%= link_to "お気に入り", favorites_booths_path, class: "btn btn-sm btn-outline-secondary" %>
            </div>

            <div>
              <% if user_signed_in? && current_user.at_least?(:cast) %>
                <% cast_booths_show = (controller_path == "cast/booths" && action_name == "show") %>

                <% if cast_booths_show %>
                  <% booth = @booth %>

                  <% if booth.archived? %>
                    <button class="btn btn-primary" disabled>スタンバイ開始</button>
                  <% else %>
                    <%= button_to "スタンバイ開始",
                          cast_booth_stream_sessions_path(booth),
                          method: :post,
                          class: "btn btn-primary" %>
                  <% end %>
                <% else %>
                  <% stream_path =
                       if current_user.cast?
                         booth = layout_current_booth
                         if booth.present?
                           booth.offline? ? cast_booth_path(booth) : live_cast_booth_path(booth)
                         else
                           cast_booths_path
                         end
                       else
                         cast_booths_path
                       end %>

                  <%= link_to "配信", stream_path, class: "btn btn-sm btn-primary" %>
                <% end %>
              <% end %>
            </div>

            <div class="d-flex gap-2 align-items-center">
              <%= link_to "ダッシュボード", dashboard_path_for(current_user), class: "btn btn-sm btn-outline-secondary" %>

              <% if user_signed_in? %>
                <%= button_to "ログアウト",
                      destroy_user_session_path,
                      method: :delete,
                      class: "btn btn-sm btn-outline-secondary" %>
              <% end %>
            </div>
          </div>
        </div>
      </footer>
    <% else %>
      <%# live だけ：Main+Footer はページ側へ移管する（#293） %>
      <%= yield %>
    <% end %>

    <%# --- Global Modal Frame (common) --- %>
    <turbo-frame
      id="modal"
      data-controller="modal"
      data-action="turbo:frame-load->modal#open">
    </turbo-frame>
  </body>
</html>
