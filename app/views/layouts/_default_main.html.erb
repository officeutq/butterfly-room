<main class="flex-grow-1 app-main-with-footer">
  <div class="container mt-3">
    <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
    <div id="flash_inner">
      <% if notice.present? %>
        <%= render "shared/flash_message", level: "success", message: notice %>
      <% end %>

      <% if alert.present? %>
        <%= render "shared/flash_message", level: "danger", message: alert %>
      <% end %>
    </div>

    <% onboarding_store = layout_current_store %>
    <% if onboarding_store&.onboarding_active? %>
      <div
        data-controller="onboarding"
        data-onboarding-step-value="<%= onboarding_store.onboarding_step %>"
        data-onboarding-skip-url-value="<%= skip_admin_onboarding_path %>"
        data-onboarding-invite-cast-image-url-value="<%= asset_path('onboarding/invite_cast.png') %>"
        data-onboarding-create-invite-image-url-value="<%= asset_path('onboarding/create_invite.png') %>"
        data-onboarding-go-dashboard-image-url-value="<%= asset_path('onboarding/go_dashboard_for_drinks.png') %>"
        data-onboarding-setup-drinks-image-url-value="<%= asset_path('onboarding/setup_drinks.png') %>">
      </div>
    <% end %>
  </div>

  <div class="container my-4">
    <%= yield %>
  </div>
</main>

<%# --- Footer (common top-level navigation) --- %>
<footer id="app_footer" class="border-top bg-body fixed-bottom">
  <div class="container-fluid app-footer-shell">
    <div class="container">
      <nav class="app-footer-nav app-footer-nav--5" aria-label="フッターナビゲーション">
        <%= link_to root_path, class: footer_nav_item_classes(active: footer_home_active?) do %>
          <i class="bi bi-house-fill app-footer-nav-icon" aria-hidden="true"></i>
          <span class="app-footer-nav-label">ホーム</span>
        <% end %>

        <%= link_to favorites_booths_path, class: footer_nav_item_classes(active: footer_favorites_active?) do %>
          <i class="bi bi-star-fill app-footer-nav-icon" aria-hidden="true"></i>
          <span class="app-footer-nav-label">お気に入り</span>
        <% end %>

        <div class="app-footer-nav-slot app-footer-nav-slot--center">
          <% if user_signed_in? && current_user.at_least?(:cast) %>
            <% booth = layout_current_booth %>

            <% if booth.present? && current_user.cast? %>
              <%= button_to enter_booth_path(booth),
                    method: :get,
                    class: "app-footer-nav-item app-footer-nav-item--live app-footer-nav-item--live-broadcast",
                    form: {
                      class: "app-footer-nav-form",
                      data: { turbo_confirm: enter_booth_switch_confirm_message(booth) }
                    } do %>
                <i class="bi bi-broadcast app-footer-nav-icon" aria-hidden="true"></i>
                <span class="app-footer-nav-label">配信</span>
              <% end %>
            <% else %>
              <%= link_to select_modal_cast_booths_path(return_to_key: "booth_live"),
                    data: { turbo_frame: "modal" },
                    class: "app-footer-nav-item app-footer-nav-item--live app-footer-nav-item--live-broadcast" do %>
                <i class="bi bi-broadcast app-footer-nav-icon" aria-hidden="true"></i>
                <span class="app-footer-nav-label">配信</span>
              <% end %>
            <% end %>
          <% end %>
        </div>

        <div class="<%= footer_nav_item_classes(extra: 'app-footer-nav-item--placeholder') %>" aria-disabled="true">
          <i class="bi bi-bell-fill app-footer-nav-icon" aria-hidden="true"></i>
          <span class="app-footer-nav-label">お知らせ</span>
        </div>

        <%= link_to dashboard_path_for(current_user),
              class: footer_nav_item_classes(active: footer_dashboard_active?),
              data: { onboarding_target_element: "footer-dashboard" } do %>
          <i class="bi bi-list app-footer-nav-icon" aria-hidden="true"></i>
          <span class="app-footer-nav-label">ダッシュボード</span>
        <% end %>
      </nav>
    </div>
  </div>
</footer>
