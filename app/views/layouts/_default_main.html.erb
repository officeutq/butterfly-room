<main class="flex-grow-1 pb-5">
  <div class="container mt-3">
    <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
    <div id="flash_inner">
      <% if notice.present? %>
        <%= render "shared/flash_message", level: "success", message: notice %>
      <% end %>

      <% if alert.present? %>
        <%= render "shared/flash_message", level: "danger", message: alert %>
      <% end %>
    </div>
  </div>

  <div class="container my-4">
    <%= yield %>
  </div>
</main>

<%# --- Footer (common top-level navigation) --- %>
<footer id="app_footer" class="border-top bg-body fixed-bottom">
  <div class="container py-2">
    <div class="d-flex justify-content-between align-items-center">
      <div class="d-flex gap-3">
        <%= link_to "ホーム", root_path, class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "お気に入り", favorites_booths_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>

      <div>
        <% if user_signed_in? && current_user.at_least?(:cast) %>
          <% cast_booths_show = (controller_path == "cast/booths" && action_name == "show") %>

          <% if cast_booths_show %>
            <% booth = @booth %>

            <% if booth.archived? %>
              <button class="btn btn-primary" disabled>スタンバイ開始</button>
            <% else %>
              <%= button_to "スタンバイ開始",
                    cast_booth_stream_sessions_path(booth),
                    method: :post,
                    class: "btn btn-primary" %>
            <% end %>
          <% else %>
            <% stream_path =
                 if current_user.cast?
                   booth = layout_current_booth
                   if booth.present?
                     booth.offline? ? cast_booth_path(booth) : live_cast_booth_path(booth)
                   else
                     cast_booths_path
                   end
                 else
                   cast_booths_path
                 end %>

            <%= link_to "配信", stream_path, class: "btn btn-sm btn-primary" %>
          <% end %>
        <% end %>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <%= link_to "ダッシュボード", dashboard_path_for(current_user), class: "btn btn-sm btn-outline-secondary" %>

        <% if user_signed_in? %>
          <%= button_to "ログアウト",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    </div>
  </div>
</footer>
