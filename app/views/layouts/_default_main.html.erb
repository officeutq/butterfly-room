<main class="flex-grow-1 app-main-with-footer">
  <div class="container mt-3">
    <%# ★常時存在する flash の箱（StoreBanGuard の turbo_stream target） %>
    <div id="flash_inner">
      <% if notice.present? %>
        <%= render "shared/flash_message", level: "success", message: notice %>
      <% end %>

      <% if alert.present? %>
        <%= render "shared/flash_message", level: "danger", message: alert %>
      <% end %>
    </div>

    <% onboarding_store = layout_current_store %>
    <% if onboarding_store&.onboarding_active? %>
      <div
        data-controller="onboarding"
        data-onboarding-step-value="<%= onboarding_store.onboarding_step %>"
        data-onboarding-skip-url-value="<%= skip_admin_onboarding_path %>"
        data-onboarding-invite-cast-image-url-value="<%= asset_path('onboarding/smiling_face.png') %>"
        data-onboarding-create-invite-image-url-value="<%= asset_path('onboarding/straight_face.png') %>"
        data-onboarding-go-dashboard-image-url-value="<%= asset_path('onboarding/straight_face.png') %>"
        data-onboarding-setup-drinks-image-url-value="<%= asset_path('onboarding/smiling_face.png') %>">
      </div>
    <% end %>
  </div>

  <div class="container my-4">
    <%= yield %>
  </div>
</main>

<%= render "layouts/footer" %>
