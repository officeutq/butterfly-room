<main class="flex-grow-1 viewer-main" data-controller="live-stage">
  <%= yield %>
</main>

<%# --- Footer (viewer main) --- %>
<footer id="app_footer" class="border-top bg-body fixed-bottom">
  <div class="container py-2">
    <div class="d-flex justify-content-between align-items-center">
      <div class="d-flex gap-3">
        <%= link_to "ホーム", root_path, class: "btn btn-sm btn-outline-secondary" %>
        <%= link_to "お気に入り", favorites_booths_path, class: "btn btn-sm btn-outline-secondary" %>
      </div>

      <div>
      </div>

      <div class="d-flex gap-2 align-items-center">
        <%= link_to "ダッシュボード", dashboard_path_for(current_user), class: "btn btn-sm btn-outline-secondary" %>

        <% if user_signed_in? %>
          <%= button_to "ログアウト",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-sm btn-outline-secondary" %>
        <% end %>
      </div>
    </div>
  </div>
</footer>
