<h1>マニュアル精算（system_admin）</h1>

<div class="alert alert-secondary" role="alert">
  テスト期間のみ使用できます。JST固定、期間は <code>[from, to)</code>（from含む / to含まない）です。
</div>

<%= form_with scope: :manual_settlement,
      url: preview_manual_system_admin_settlements_path,
      method: :post,
      data: { turbo: false } do |f| %>
  <% if @form.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @form.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :store_id, "対象店舗", class: "form-label" %>
    <%= f.select :store_id,
          Store.order(id: :desc).map { |s| [s.name, s.id] },
          { include_blank: "選択してください" },
          class: "form-select",
          required: true %>
  </div>

  <div class="row g-3">
    <div class="col-md-6">
      <%= f.label :period_from, "period_from（JST）", class: "form-label" %>
      <%= f.datetime_field :period_from, class: "form-control", required: true %>
      <div class="form-text">from は含みます</div>
    </div>

    <div class="col-md-6">
      <%= f.label :period_to, "period_to（JST）", class: "form-label" %>
      <%= f.datetime_field :period_to, class: "form-control", required: true %>
      <div class="form-text">to は含みません</div>
    </div>
  </div>

  <div class="mt-3 d-flex gap-2">
    <%= f.submit "プレビュー", class: "btn btn-primary" %>
    <%= link_to "ダッシュボードへ戻る", dashboard_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>

<% if @preview.present? %>
  <hr class="my-4">

  <h2 class="h5 mb-3">プレビュー</h2>

  <table class="table table-sm">
    <tbody>
      <tr>
        <th style="width: 220px;">対象期間（JST）</th>
        <td>
          <%= l(@preview[:period_from].in_time_zone("Asia/Tokyo")) %>
          〜
          <%= l(@preview[:period_to].in_time_zone("Asia/Tokyo")) %>
          （toは含まない）
        </td>
      </tr>
      <tr>
        <th>gross_yen</th>
        <td><%= @preview[:gross_yen] %></td>
      </tr>
      <tr>
        <th>store_share_yen（gross×0.7 floor）</th>
        <td><%= @preview[:store_share_yen] %></td>
      </tr>
      <tr>
        <th>platform_fee_yen</th>
        <td><%= @preview[:platform_fee_yen] %></td>
      </tr>
      <tr>
        <th>carryover_yen（表示のみ）</th>
        <td><%= @preview[:carryover_yen] %></td>
      </tr>
    </tbody>
  </table>

  <div class="alert alert-warning" role="alert">
    この画面の「確定」は settlement 台帳を作成するだけです。支払や残高表示は扱いません。
  </div>

  <%= form_with scope: :manual_settlement,
        url: create_manual_system_admin_settlements_path,
        method: :post,
        data: { turbo: false } do |f| %>
    <%= f.hidden_field :store_id, value: @form.store_id %>
    <%= f.hidden_field :period_from, value: @form.period_from %>
    <%= f.hidden_field :period_to, value: @form.period_to %>

    <div class="d-flex gap-2">
      <%= f.submit "確定（confirmedで作成）", class: "btn btn-danger", data: { turbo_confirm: "この内容で精算を確定します。よろしいですか？" } %>
      <%= link_to "キャンセル", dashboard_path, class: "btn btn-outline-secondary" %>
    </div>
  <% end %>
<% end %>
