<h1>精算一覧</h1>

<div class="alert alert-secondary" role="alert">
  状態遷移：draft → confirmed → exported → paid<br>
  CSV生成は「confirmed を複数選択 → 1ファイル生成」です（partial成功禁止）。<br>
  confirmed のカードだけにチェックボックスが出ます。
</div>

<%= form_with url: export_csv_system_admin_settlements_path, method: :post do %>
  <div class="card mb-3">
    <div class="card-body">
      <div class="row g-2 align-items-end">
        <div class="col-md-4">
          <label class="form-label">status（複数可）</label>
          <select name="statuses[]" class="form-select" multiple size="4">
            <% @status_options.each do |st| %>
              <option value="<%= st %>" <%= "selected" if Array(params[:statuses]).presence&.include?(st) || (params[:statuses].blank? && %w[draft confirmed exported].include?(st)) %>><%= st %></option>
            <% end %>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label">kind（任意）</label>
          <select name="kinds[]" class="form-select" multiple size="2">
            <% @kind_options.each do |k| %>
              <option value="<%= k %>" <%= "selected" if Array(params[:kinds]).include?(k) %>><%= k %></option>
            <% end %>
          </select>
        </div>

        <div class="col-md-3">
          <label class="form-label">store（任意）</label>
          <select name="store_id" class="form-select">
            <option value=""></option>
            <% @stores.each do |s| %>
              <option value="<%= s.id %>" <%= "selected" if params[:store_id].to_s == s.id.to_s %>><%= s.name %></option>
            <% end %>
          </select>
        </div>

        <div class="col-md-2">
          <label class="form-label">month（任意）</label>
          <input type="month" name="month" value="<%= params[:month] %>" class="form-control">
        </div>

        <div class="col-12 mt-2 d-flex gap-2">
          <%= button_tag "絞り込む", type: "submit", formaction: system_admin_settlements_path, formmethod: :get, class: "btn btn-outline-primary" %>
          <%= link_to "リセット", system_admin_settlements_path, class: "btn btn-outline-secondary" %>
        </div>
      </div>
    </div>
  </div>

  <% if @settlements.blank? %>
    <div class="alert alert-warning" role="alert">
      表示できる精算はありません。
    </div>
  <% else %>
    <div class="referral-codes-list">
      <% @settlements.each do |s| %>
        <div class="card referral-code-card">
          <div class="card-body">
            <div class="referral-code-row">
              <div class="referral-code-label">選択</div>
              <div class="referral-code-value">
                <% if s.confirmed? %>
                  <div class="form-check m-0">
                    <%= check_box_tag "settlement_ids[]", s.id, false, class: "form-check-input" %>
                  </div>
                <% else %>
                  <span class="text-muted small">対象外</span>
                <% end %>
              </div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">期間</div>
              <div class="referral-code-value text-muted small">
                <%= l(s.period_from) %>〜<%= l(s.period_to) %>
              </div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">store</div>
              <div class="referral-code-value fw-semibold"><%= s.store.name %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">kind</div>
              <div class="referral-code-value"><%= s.kind %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">status</div>
              <div class="referral-code-value"><%= s.status %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">gross</div>
              <div class="referral-code-value"><%= s.gross_yen %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">share</div>
              <div class="referral-code-value"><%= s.store_share_yen %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">fee</div>
              <div class="referral-code-value"><%= s.platform_fee_yen %></div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">confirmed</div>
              <div class="referral-code-value text-muted small">
                <%= s.confirmed_at.present? ? l(s.confirmed_at) : "-" %>
              </div>
            </div>

            <div class="referral-code-row">
              <div class="referral-code-label">exported</div>
              <div class="referral-code-value text-muted small">
                <%= s.exported_at.present? ? l(s.exported_at) : "-" %>
              </div>
            </div>

            <div class="pt-3">
              <div class="referral-code-inline-actions justify-content-end">
                <%= link_to "詳細", system_admin_settlement_path(s), class: "btn btn-outline-secondary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="d-flex gap-2 mt-3">
    <%= button_tag "選択したconfirmedをCSV生成（1ファイル）",
          type: "submit",
          class: "btn btn-primary",
          data: { turbo_confirm: "選択した confirmed を対象に、振込CSVを1ファイル生成します。よろしいですか？" } %>
  </div>
<% end %>
