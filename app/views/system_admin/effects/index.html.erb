<h1>Effect管理</h1>

<div class="mb-3 d-flex gap-2">
  <%= link_to "新規作成", new_system_admin_effect_path, class: "btn btn-primary" %>
</div>

<% if @effects.blank? %>
  <div class="alert alert-warning" role="alert">
    表示できるEffectはありません。
  </div>
<% else %>
  <div class="referral-codes-list">
    <% @effects.each do |e| %>
      <div class="card referral-code-card <%= "text-muted" unless e.enabled %>">
        <div class="card-body">
          <div class="referral-code-row">
            <div class="referral-code-label">ID</div>
            <div class="referral-code-value"><%= e.id %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">表示名</div>
            <div class="referral-code-value fw-semibold"><%= e.name %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">key</div>
            <div class="referral-code-value"><%= e.key %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">zip</div>
            <div class="referral-code-value text-break"><%= e.zip_filename %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">icon</div>
            <div class="referral-code-value text-break"><%= e.icon_path.presence || "-" %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">position</div>
            <div class="referral-code-value"><%= e.position %></div>
          </div>

          <div class="referral-code-row">
            <div class="referral-code-label">enabled</div>
            <div class="referral-code-value">
              <%= form_with model: [:system_admin, e], method: :patch, class: "d-inline" do |f| %>
                <%= f.hidden_field :enabled, value: (!e.enabled).to_s %>
                <%= f.submit(
                      e.enabled ? "有効" : "無効",
                      class: "btn btn-sm #{e.enabled ? "btn-success" : "btn-outline-secondary"}"
                    ) %>
              <% end %>
            </div>
          </div>

          <div class="pt-3">
            <div class="referral-code-inline-actions justify-content-end">
              <%= link_to "編集", edit_system_admin_effect_path(e), class: "btn btn-outline-secondary btn-sm" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
