<%= form_with model: [:system_admin, referral_code] do |f| %>
  <% if referral_code.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% referral_code.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :code, "code（ユニーク）", class: "form-label" %>
    <%= f.text_field :code, class: "form-control", required: true, autocomplete: "off" %>
    <div class="form-text">店舗登録時に入力される共通コード（許可リスト）</div>
  </div>

  <div class="mb-3">
    <%= f.label :label, "label（識別用）", class: "form-label" %>
    <%= f.text_field :label, class: "form-control" %>
    <div class="form-text">例：営業A / 媒体 / 施策名</div>
  </div>

  <div class="mb-3">
    <%= f.label :expires_at, "expires_at（任意）", class: "form-label" %>
    <%= f.datetime_field :expires_at, class: "form-control" %>
    <div class="form-text">期限切れの場合、店舗登録では使用不可になります</div>
  </div>

  <div class="form-check mb-3">
    <%= f.check_box :enabled, class: "form-check-input" %>
    <%= f.label :enabled, "enabled（有効）", class: "form-check-label" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit referral_code.persisted? ? "更新する" : "作成する", class: "btn btn-primary" %>
    <%= link_to "キャンセル", system_admin_referral_codes_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
