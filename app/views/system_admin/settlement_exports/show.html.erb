<h1>振込CSV 詳細</h1>

<table class="table table-sm" style="max-width: 720px;">
  <tbody>
    <tr><th style="width: 200px;">ID</th><td><%= @export.id %></td></tr>
    <tr><th>Format</th><td><%= @export.format %></td></tr>
    <tr><th>Seq</th><td><%= @export.file_seq %></td></tr>
    <tr><th>Record count</th><td><%= @export.record_count %></td></tr>
    <tr><th>Total amount</th><td><%= @export.total_amount_yen %></td></tr>
    <tr><th>Generated by</th><td><%= @export.generated_by_user.email %></td></tr>
    <tr><th>Created</th><td><%= l(@export.created_at) %></td></tr>
  </tbody>
</table>

<div class="d-flex gap-2">
  <% if @export.file.attached? %>
    <%= link_to "CSVをダウンロード",
          rails_blob_path(@export.file, disposition: "attachment"),
          class: "btn btn-primary" %>
  <% else %>
    <span class="text-muted">ファイル未生成</span>
  <% end %>

  <%= link_to "一覧へ戻る", system_admin_settlement_exports_path, class: "btn btn-outline-secondary" %>
</div>
