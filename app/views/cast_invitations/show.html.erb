<div style="max-width: 720px;">
  <h1 class="h4 mb-3">キャスト招待</h1>

  <div class="card mb-3">
    <div class="card-body">
      <div class="mb-2">
        <span class="text-muted">店舗：</span>
        <strong><%= @invitation.store.name %></strong>
      </div>

      <% if @invitation.note.present? %>
        <div class="mb-2">
          <span class="text-muted">メモ：</span>
          <span><%= @invitation.note %></span>
        </div>
      <% end %>

      <div class="mb-2">
        <span class="text-muted">期限：</span>
        <span><%= l(@invitation.expires_at) %></span>
      </div>

      <div class="mb-0">
        <span class="text-muted">状態：</span>
        <span><%= @invitation.status_label %></span>
      </div>
    </div>
  </div>

  <% if !user_signed_in? %>
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-2">キャスト招待を受ける</h2>
        <p class="text-muted mb-3">
          この招待を受けるには cast アカウントが必要です。
        </p>

        <div class="d-grid gap-2">
          <%= link_to "新規 cast アカウントを作成して招待を受ける",
                cast_sign_up_path(token: params[:token]),
                class: "btn btn-primary" %>

          <%= link_to "既存の cast アカウントで招待を受ける",
                new_user_session_path(invite_token: params[:token]),
                class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>

  <% elsif !current_user.cast? %>
    <div class="card mb-3">
      <div class="card-body">
        <h2 class="h5 mb-2">cast アカウントで招待を受けてください</h2>
        <p class="text-muted mb-3">
          この招待は cast アカウントでのみ承認できます。<br>
          現在は cast 以外のアカウントでログインしています。
        </p>

        <div class="d-grid gap-2 d-sm-flex">
          <%= button_to "ログアウトして cast アカウントでログインする",
                destroy_user_session_path,
                method: :delete,
                class: "btn btn-primary" %>

          <%= link_to "cast アカウントを新規作成する",
                cast_sign_up_path(token: params[:token]),
                class: "btn btn-outline-primary" %>
        </div>
      </div>
    </div>

  <% else %>
    <% if @already_member %>
      <div class="alert alert-success" role="alert">
        この店舗にはすでにキャストとして登録されています。
      </div>

      <div class="d-flex gap-2">
        <%= link_to "トップへ戻る", root_path, class: "btn btn-outline-secondary" %>
      </div>

    <% elsif !@invitation.usable? %>
      <div class="alert alert-danger" role="alert">
        この招待は使用できません（期限切れ / 使用済み）。
      </div>

    <% else %>
      <div class="alert alert-info" role="alert">
        上記の店舗にキャストとして参加します。よろしければ承認してください。
      </div>

      <div class="d-flex gap-2">
        <%= button_to "承認する",
              accept_cast_invitation_path(params[:token]),
              method: :post,
              class: "btn btn-primary",
              data: { turbo_confirm: "この店舗（#{@invitation.store.name}）のキャスト招待を承認しますか？" } %>

        <%= link_to "キャンセル", root_path, class: "btn btn-outline-secondary" %>
      </div>
    <% end %>
  <% end %>
</div>
