<% content_for :title, "ポイント購入" %>

<% if @status == "cancel" %>
  <div class="alert alert-warning">購入はキャンセルされました。</div>
<% elsif @status == "success" %>
  <div class="alert alert-info">
    お支払い手続きを受け付けました。<br>
    クレジットカード等で決済済みの場合は、ポイント反映まで少し時間がかかる場合があります。<br>
    コンビニ決済の場合は、店頭でのお支払い完了後にポイントが反映されます。
  </div>
<% else %>
  <div class="alert alert-danger">購入に失敗した可能性があります。</div>
<% end %>

<% if @wallet.present? %>
  <p>現在の残高: <strong><%= @wallet.available_points %>pt</strong></p>
<% else %>
  <p class="text-muted">Wallet が見つかりません。</p>
<% end %>

<% if @return_to.present? %>
  <%= link_to "元のページへ戻る", @return_to, class: "btn btn-primary" %>
<% else %>
  <%= link_to "トップへ戻る", root_path, class: "btn btn-outline-secondary" %>
<% end %>
